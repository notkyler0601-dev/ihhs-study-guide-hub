# Copy this file to .env and fill in the values.
# Leave empty to run in local-only mode (no cross-device sync).

# Supabase project URL. From your project dashboard > Settings > API
PUBLIC_SUPABASE_URL=

# Supabase anon/public key. From the same page.
# Safe to expose in the browser as long as Row-Level Security is enabled
# (which schema.sql sets up automatically).
PUBLIC_SUPABASE_ANON_KEY=
