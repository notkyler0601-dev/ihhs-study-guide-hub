---
import { getCollection, render } from 'astro:content';
import ParodyLayout from '../../layouts/ParodyLayout.astro';

export async function getStaticPaths() {
  const all = await getCollection('parody');
  return all.map((g) => ({
    params: { slug: g.id.replace(/\.(md|mdx)$/, '') },
    props: { guide: g },
  }));
}

const { guide } = Astro.props;
const { Content } = await render(guide);
---

<ParodyLayout guide={guide}>
  <Content />
</ParodyLayout>
