---
import SecretLayout from '../../layouts/SecretLayout.astro';
import { getCollection } from 'astro:content';

// Server-render the parody index. The gate hides it until unlocked.
const all = await getCollection('parody');
const guides = [...all]
  .map((g) => ({ slug: g.id.replace(/\.(md|mdx)$/, ''), ...g.data }))
  .sort((a, b) => b.date.valueOf() - a.date.valueOf());
---

<SecretLayout title="Restricted · IHHS" description="Restricted area.">
  <main class="flex-1 flex items-center justify-center px-4 py-16">
    <div class="w-full max-w-md">
      <!-- Locked view ------------------------------------------------- -->
      <section data-locked-view>
        <div class="mb-6 flex items-center justify-center">
          <span class="inline-flex items-center justify-center h-14 w-14 rounded-2xl bg-ink-900 dark:bg-ink-50 text-white dark:text-ink-900 shadow-lift">
            <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="4" y="11" width="16" height="10" rx="2"/><path d="M8 11V7a4 4 0 0 1 8 0v4"/>
            </svg>
          </span>
        </div>
        <h1 class="text-center font-serif text-2xl font-semibold tracking-tight">Restricted area</h1>
        <p class="mt-2 text-center text-sm text-ink-500 dark:text-ink-400">
          Enter the password to continue.
        </p>

        <form data-unlock-form class="mt-6 surface rounded-2xl p-5 shadow-soft">
          <label for="pw" class="sr-only">Password</label>
          <input
            id="pw"
            type="password"
            autocomplete="off"
            autocapitalize="off"
            autocorrect="off"
            spellcheck="false"
            placeholder="Password"
            class="w-full bg-transparent border-b border-ink-200 dark:border-ink-800 px-1 py-2 text-base placeholder-ink-400 focus:outline-none focus:border-accent-500"
          />
          <p data-unlock-error class="hidden mt-3 text-sm text-rose-600 dark:text-rose-400">Wrong password.</p>
          <button
            type="submit"
            class="mt-5 w-full inline-flex items-center justify-center gap-2 rounded-xl bg-accent-700 hover:bg-accent-800 dark:bg-accent-600 dark:hover:bg-accent-500 text-white font-medium text-sm py-2.5 transition-colors"
          >
            Unlock
          </button>
        </form>

        <p class="mt-4 text-center text-xs text-ink-400">
          <a href="/" class="hover:text-accent-700 dark:hover:text-accent-400">← Back to the main site</a>
        </p>
      </section>

      <!-- Unlocked view ----------------------------------------------- -->
      <section data-unlocked-view class="hidden">
        <div class="flex items-center justify-between mb-5">
          <div>
            <div class="text-[11px] uppercase tracking-[0.18em] text-ink-500 font-semibold">Secret library</div>
            <h1 class="font-serif text-3xl font-semibold tracking-tight mt-1">Parody guides</h1>
          </div>
          <button data-lock type="button" class="text-xs text-ink-500 hover:text-accent-700 dark:hover:text-accent-400">Lock</button>
        </div>

        {guides.length === 0 ? (
          <div class="surface rounded-2xl p-8 text-center">
            <p class="text-sm text-ink-500">No parody guides yet. Drop a <code>.mdx</code> file in <code>src/content/parody/</code>.</p>
          </div>
        ) : (
          <ul class="space-y-3">
            {guides.map((g) => (
              <li>
                <a href={`/secret/${g.slug}`} class="block surface rounded-xl p-4 card-hover">
                  <div class="font-serif text-lg font-semibold tracking-tight">{g.title}</div>
                  <p class="mt-1 text-sm text-ink-600 dark:text-ink-300">{g.description}</p>
                </a>
              </li>
            ))}
          </ul>
        )}

        <p class="mt-6 text-center text-xs text-ink-400">
          <a href="/" class="hover:text-accent-700 dark:hover:text-accent-400">← Back to the main site</a>
        </p>
      </section>
    </div>
  </main>
</SecretLayout>

<script>
  import { sha256Hex, isUnlocked, setUnlocked, PASSWORD_HASH } from '../../lib/secret';

  const lockedView = document.querySelector('[data-locked-view]') as HTMLElement;
  const unlockedView = document.querySelector('[data-unlocked-view]') as HTMLElement;
  const form = document.querySelector('[data-unlock-form]') as HTMLFormElement;
  const errEl = document.querySelector('[data-unlock-error]') as HTMLElement;
  const lockBtn = document.querySelector('[data-lock]') as HTMLButtonElement | null;
  const input = document.querySelector('#pw') as HTMLInputElement;

  const showUnlocked = () => {
    lockedView.classList.add('hidden');
    unlockedView.classList.remove('hidden');
  };
  const showLocked = () => {
    unlockedView.classList.add('hidden');
    lockedView.classList.remove('hidden');
    setTimeout(() => input?.focus(), 50);
  };

  if (isUnlocked()) {
    // Already unlocked. If we were sent here from a guide page, bounce back.
    const ret = sessionStorage.getItem('ihhs:secret:return');
    if (ret && ret !== '/secret' && ret.startsWith('/secret/')) {
      sessionStorage.removeItem('ihhs:secret:return');
      window.location.replace(ret);
    } else {
      showUnlocked();
    }
  } else {
    setTimeout(() => input?.focus(), 50);
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    errEl.classList.add('hidden');
    const pw = input.value;
    if (!pw) return;
    const hash = await sha256Hex(pw);
    if (hash === PASSWORD_HASH) {
      setUnlocked(true);
      input.value = '';
      const ret = sessionStorage.getItem('ihhs:secret:return');
      if (ret && ret !== '/secret' && ret.startsWith('/secret/')) {
        sessionStorage.removeItem('ihhs:secret:return');
        window.location.replace(ret);
        return;
      }
      showUnlocked();
    } else {
      errEl.classList.remove('hidden');
      input.select();
    }
  });

  lockBtn?.addEventListener('click', () => {
    setUnlocked(false);
    showLocked();
  });
</script>
