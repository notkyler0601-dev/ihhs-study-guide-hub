---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const guides = await getCollection('guides', ({ data }) => !data.draft);
const existingSubjects = [...new Set(guides.map((g) => g.data.subject))].sort();
const suggestedSubjects = [
  ...existingSubjects,
  ...['Biology', 'Chemistry', 'Physics', 'Math', 'English', 'History', 'Spanish', 'Computer Science']
    .filter((s) => !existingSubjects.includes(s)),
];
---

<BaseLayout
  title="Request a guide"
  description="Tell us what you want to study and we'll build a deep-dive guide for it."
>
  <section class="container-prose py-14 lg:py-20">
    <div class="max-w-2xl mb-10 stagger-fade">
      <div class="text-xs uppercase tracking-[0.18em] text-ink-500 font-semibold mb-3">Request</div>
      <h1 class="font-serif text-4xl sm:text-5xl font-semibold tracking-tight text-balance">
        Need a guide on something? <span class="gradient-text">Tell us.</span>
      </h1>
      <p class="mt-4 text-lg text-ink-600 dark:text-ink-300 leading-relaxed text-pretty">
        Submit a topic and we'll build a full deep-dive guide for it.
        Include as much detail as you can, the more context you give, the better the guide.
      </p>
    </div>

    <!-- Sign-in gate, shown by default. JS hides this and reveals the form when the user is signed in. -->
    <div id="request-gate" class="surface rounded-2xl p-8 sm:p-10 text-center">
      <div class="inline-flex items-center justify-center h-14 w-14 rounded-full bg-accent-100 dark:bg-accent-900/40 text-accent-700 dark:text-accent-300 text-2xl mb-5">
        <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>
        </svg>
      </div>
      <h2 class="font-serif text-2xl sm:text-3xl font-semibold tracking-tight mb-2">Sign in to submit a request</h2>
      <p class="text-ink-600 dark:text-ink-300 max-w-md mx-auto mb-6">
        We require an account so we can follow up on requests, prevent spam, and credit you for ideas that become guides.
      </p>
      <div class="flex flex-wrap items-center justify-center gap-3">
        <a href="/login?next=/request" class="inline-flex items-center gap-2 px-4 py-2.5 rounded-xl bg-accent-700 hover:bg-accent-800 dark:bg-accent-600 dark:hover:bg-accent-500 text-white text-sm font-medium transition-all">
          Log in
        </a>
        <a href="/signup?next=/request" class="inline-flex items-center gap-2 px-4 py-2.5 rounded-xl surface text-sm font-medium hover:border-accent-400 dark:hover:border-accent-600 transition-all">
          Create an account
        </a>
      </div>
    </div>

    <form id="request-form" class="hidden surface rounded-2xl p-6 sm:p-8 space-y-6">
      <div data-request-as class="text-xs text-ink-500 dark:text-ink-400 flex items-center gap-2 px-3 py-2 rounded-lg bg-ink-50 dark:bg-ink-900/60 border border-ink-200 dark:border-ink-800">
        <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        Submitting as <strong data-request-as-name class="text-ink-900 dark:text-ink-50"></strong>
      </div>

      <div class="grid sm:grid-cols-2 gap-5">
        <label class="block">
          <span class="text-xs uppercase tracking-[0.14em] font-semibold text-ink-500 dark:text-ink-400">
            Subject <span class="text-accent-700">*</span>
          </span>
          <select
            name="subject"
            required
            class="form-input mt-2"
          >
            <option value="">Pick a subject...</option>
            {suggestedSubjects.map((s) => <option value={s}>{s}</option>)}
            <option value="Other">Other (specify in topic)</option>
          </select>
        </label>

        <label class="block">
          <span class="text-xs uppercase tracking-[0.14em] font-semibold text-ink-500 dark:text-ink-400">
            When do you need it?
          </span>
          <select name="urgency" class="form-input mt-2">
            <option value="No rush">No rush, whenever</option>
            <option value="This month">This month</option>
            <option value="Next 2 weeks">Next 2 weeks</option>
            <option value="This week">This week (test soon!)</option>
          </select>
        </label>
      </div>

      <label class="block">
        <span class="text-xs uppercase tracking-[0.14em] font-semibold text-ink-500 dark:text-ink-400">
          Topic <span class="text-accent-700">*</span>
        </span>
        <input
          type="text"
          name="topic"
          required
          maxlength="120"
          placeholder="e.g. Mitosis vs meiosis, derivatives, World War I causes"
          class="form-input mt-2"
        />
      </label>

      <label class="block">
        <span class="text-xs uppercase tracking-[0.14em] font-semibold text-ink-500 dark:text-ink-400">
          What do you want to understand? <span class="text-accent-700">*</span>
        </span>
        <textarea
          name="goal"
          required
          rows="4"
          maxlength="800"
          placeholder="What's confusing? What does the test cover? What have you tried? The more specific, the better the guide."
          class="form-input mt-2 resize-y"
        ></textarea>
        <span class="text-[11px] text-ink-400 mt-1 block"><span data-counter="goal">0</span> / 800</span>
      </label>

      <label class="block">
        <span class="text-xs uppercase tracking-[0.14em] font-semibold text-ink-500 dark:text-ink-400">
          Source material <span class="text-ink-400 font-normal normal-case tracking-normal">(optional)</span>
        </span>
        <textarea
          name="sources"
          rows="3"
          maxlength="500"
          placeholder="Textbook chapter, lecture notes, links, anything we should reference."
          class="form-input mt-2 resize-y"
        ></textarea>
      </label>

      <div id="request-error" class="hidden text-sm text-accent-700 dark:text-accent-400 bg-accent-50 dark:bg-accent-900/30 rounded-lg px-4 py-3"></div>

      <div class="pt-2 flex flex-col sm:flex-row sm:items-center justify-between gap-4 border-t border-ink-200 dark:border-ink-800">
        <p class="text-xs text-ink-500 dark:text-ink-400 leading-relaxed">
          We'll review every request and start on the most popular ones first.
        </p>
        <button
          type="submit"
          id="request-submit"
          class="inline-flex items-center justify-center gap-2 px-5 py-3 rounded-xl bg-accent-700 hover:bg-accent-800 dark:bg-accent-600 dark:hover:bg-accent-500 text-white font-medium text-sm shadow-soft hover:shadow-lift transition-all whitespace-nowrap disabled:opacity-50"
        >
          Submit request
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </button>
      </div>
    </form>

    <div id="request-success" class="hidden surface rounded-2xl p-10 text-center stagger-fade">
      <div class="inline-flex items-center justify-center h-14 w-14 rounded-full bg-accent-100 dark:bg-accent-900/40 text-accent-700 dark:text-accent-300 text-2xl mb-5">
        ✓
      </div>
      <h2 class="font-serif text-2xl sm:text-3xl font-semibold tracking-tight mb-2">Request received</h2>
      <p class="text-ink-600 dark:text-ink-300 max-w-md mx-auto mb-6">
        Thanks! We'll review it and start on the guide soon.
      </p>
      <div class="flex flex-wrap items-center justify-center gap-3">
        <a href="/library" class="inline-flex items-center gap-2 px-4 py-2.5 rounded-xl bg-accent-700 hover:bg-accent-800 dark:bg-accent-600 dark:hover:bg-accent-500 text-white text-sm font-medium transition-all">
          Browse other guides
        </a>
        <button
          type="button"
          id="request-another"
          class="inline-flex items-center gap-2 px-4 py-2.5 rounded-xl surface text-sm font-medium hover:border-accent-400 dark:hover:border-accent-600 transition-all"
        >
          Submit another
        </button>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .form-input {
    @apply block w-full rounded-lg border border-ink-200 dark:border-ink-800 bg-white dark:bg-ink-900;
    @apply px-3 py-2.5 text-sm text-ink-900 dark:text-ink-50;
    @apply placeholder-ink-400 dark:placeholder-ink-500;
    @apply focus:outline-none focus:border-accent-500 focus:ring-2 focus:ring-accent-500/20;
    @apply transition-colors;
  }
</style>

<script>
  import { supabase, isCloudMode } from '../lib/supabase';
  import { currentUser, onAuthChange } from '../lib/auth';

  const setup = () => {
    const form = document.getElementById('request-form') as HTMLFormElement | null;
    const success = document.getElementById('request-success');
    const gate = document.getElementById('request-gate');
    const again = document.getElementById('request-another');
    const errEl = document.getElementById('request-error');
    const submitBtn = document.getElementById('request-submit') as HTMLButtonElement | null;
    const asName = document.querySelector('[data-request-as-name]');
    if (!form || !success || !gate || !errEl || !submitBtn) return;

    // Visibility based on auth state.
    const showForUser = () => {
      const me = currentUser();
      if (me) {
        gate.classList.add('hidden');
        form.classList.remove('hidden');
        success.classList.add('hidden');
        if (asName) asName.textContent = `${me.displayName} (@${me.username})`;
      } else {
        gate.classList.remove('hidden');
        form.classList.add('hidden');
        success.classList.add('hidden');
      }
    };
    showForUser();
    onAuthChange(showForUser);

    // Live char counter for goal textarea.
    document.querySelectorAll('[data-counter]').forEach((el) => {
      const name = el.getAttribute('data-counter');
      const field = form.querySelector<HTMLTextAreaElement>(`[name="${name}"]`);
      if (!field) return;
      const update = () => { (el as HTMLElement).textContent = String(field.value.length); };
      field.addEventListener('input', update);
      update();
    });

    const reset = () => {
      form.reset();
      success.classList.add('hidden');
      const me = currentUser();
      if (me) form.classList.remove('hidden');
      else gate.classList.remove('hidden');
      window.scrollTo({ top: 0, behavior: 'smooth' });
      document.querySelectorAll('[data-counter]').forEach((el) => { (el as HTMLElement).textContent = '0'; });
    };
    again?.addEventListener('click', reset);

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      errEl.classList.add('hidden');

      const me = currentUser();
      if (!me) {
        errEl.textContent = 'Please sign in to submit a request.';
        errEl.classList.remove('hidden');
        return;
      }

      submitBtn.disabled = true;
      const data = Object.fromEntries(new FormData(form)) as Record<string, string>;

      // Cloud mode: insert into Supabase. RLS blocks unauthenticated inserts server-side too.
      if (isCloudMode()) {
        const sb = supabase();
        if (sb) {
          const { error } = await sb.from('requests').insert({
            subject: data.subject,
            topic: data.topic,
            urgency: data.urgency || null,
            goal: data.goal,
            sources: data.sources || null,
            name: me.displayName,
            email: me.email ?? null,
            user_id: me.id,
          });
          submitBtn.disabled = false;
          if (!error) {
            form.classList.add('hidden');
            success.classList.remove('hidden');
            window.scrollTo({ top: 0, behavior: 'smooth' });
            return;
          }
          errEl.textContent = 'Could not submit: ' + error.message;
          errEl.classList.remove('hidden');
          return;
        }
      }

      // Local mode (no Supabase): show success but stash to localStorage for the admin to import later.
      try {
        const key = 'ihhs:local-requests';
        const existing = JSON.parse(localStorage.getItem(key) || '[]');
        existing.push({ ...data, name: me.displayName, email: me.email, user_id: me.id, at: new Date().toISOString() });
        localStorage.setItem(key, JSON.stringify(existing));
      } catch {}
      submitBtn.disabled = false;
      form.classList.add('hidden');
      success.classList.remove('hidden');
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  };
  setup();
  document.addEventListener('astro:after-swap', setup);
</script>
