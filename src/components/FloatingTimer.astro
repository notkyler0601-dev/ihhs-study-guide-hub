---
// Floating Pomodoro timer fixed to the bottom-left corner of every guide page.
// State persists in sessionStorage so it survives Astro View Transitions
// navigation between guides. Collapsible to a tiny clock-only pill.
//
// Lock-in mode: clicking Start during a work session takes over the whole
// window with a fullscreen focus overlay, requests a screen wake lock so the
// display doesn't sleep, and counts how many times the user tabs away.
// Stopping early requires a 2-second press-and-hold to add friction.
//
// Mounted globally from GuideLayout.astro, so guide authors don't need to
// import or invoke it. To opt-out on a specific page, pass `floatingTimer={false}`
// to BaseLayout (not yet wired in; add when needed).
interface Props {
  workMin?: number;
  shortBreakMin?: number;
  longBreakMin?: number;
  cyclesUntilLong?: number;
}
const { workMin = 25, shortBreakMin = 5, longBreakMin = 15, cyclesUntilLong = 4 } = Astro.props;
const conf = JSON.stringify({ workMin, shortBreakMin, longBreakMin, cyclesUntilLong });
---

<aside id="floating-timer" data-ft data-conf={conf} class="no-print fixed bottom-4 left-4 z-40 select-none" aria-label="Study timer">
  <div data-ft-card class="surface rounded-xl shadow-lift overflow-hidden text-ink-900 dark:text-ink-50">
    <header class="flex items-center justify-between gap-2 px-3 py-1.5 border-b border-ink-200 dark:border-ink-800 bg-ink-50/80 dark:bg-ink-900/80">
      <span data-ft-mode class="text-[11px] font-semibold tracking-tight">Lock in Twin🥀</span>
      <div class="flex items-center gap-0.5">
        <button data-ft-collapse type="button" aria-label="Collapse" class="px-1.5 text-ink-400 hover:text-accent-700 dark:hover:text-accent-400 leading-none">
          <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M5 12h14"/></svg>
        </button>
        <button data-ft-close type="button" aria-label="Hide timer" class="px-1.5 text-ink-400 hover:text-rose-500 leading-none">
          <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M6 6l12 12M6 18L18 6"/></svg>
        </button>
      </div>
    </header>
    <div data-ft-body class="px-3 py-2.5">
      <div data-ft-time class="font-serif text-3xl font-semibold gradient-text tabular-nums text-center leading-none mb-2">25:00</div>
      <div class="flex items-center justify-center gap-1.5">
        <button data-ft-toggle type="button" class="px-3 py-1 rounded-md bg-accent-700 hover:bg-accent-800 dark:bg-accent-600 dark:hover:bg-accent-500 text-white text-xs font-medium min-w-[60px]">Start</button>
        <button data-ft-skip type="button" aria-label="Skip" class="h-7 w-7 grid place-items-center rounded-md bg-ink-100 dark:bg-ink-800 hover:bg-ink-200 dark:hover:bg-ink-700">
          <svg class="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m13 5 7 7-7 7M5 5l7 7-7 7"/></svg>
        </button>
        <button data-ft-reset type="button" aria-label="Reset" class="h-7 w-7 grid place-items-center rounded-md bg-ink-100 dark:bg-ink-800 hover:bg-ink-200 dark:hover:bg-ink-700">
          <svg class="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 1 0 3-6.7L3 8M3 3v5h5"/></svg>
        </button>
      </div>
      <label class="mt-2 flex items-center gap-1.5 text-[10px] text-ink-500 cursor-pointer select-none justify-center">
        <input data-ft-lock-toggle type="checkbox" checked class="h-3 w-3 accent-accent-600" />
        Lock screen on Start
      </label>
      <div class="mt-1 text-[10px] text-center text-ink-500">Cycle <span data-ft-cycle class="font-semibold text-ink-900 dark:text-ink-50">1</span></div>
    </div>
  </div>

  <!-- Collapsed pill (shown when user clicks the dash) -->
  <button data-ft-pill type="button" class="hidden surface rounded-full shadow-lift px-3 py-1.5 flex items-center gap-2 text-xs font-mono">
    <span data-ft-pill-time class="tabular-nums font-semibold">25:00</span>
    <svg class="h-3 w-3 text-ink-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="m6 9 6 6 6-6"/></svg>
  </button>

  <!-- Hidden re-show button (shown when user clicks ×) -->
  <button data-ft-show type="button" class="hidden h-9 w-9 grid place-items-center rounded-full surface shadow-lift text-ink-700 dark:text-ink-200 hover:text-accent-700 dark:hover:text-accent-400" aria-label="Show study timer">
    <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="12" cy="13" r="8"/><path d="M12 9v4l2 2M9 2h6"/>
    </svg>
  </button>
</aside>

<!-- LOCK-IN OVERLAY: covers the entire viewport when a work session is running. -->
<div data-ft-lock class="hidden fixed inset-0 z-[100] bg-black text-white" role="dialog" aria-label="Lock-in mode">
  <div class="absolute inset-0 overflow-hidden pointer-events-none" aria-hidden="true">
    <div data-ft-lock-glow class="absolute -top-1/4 left-1/2 -translate-x-1/2 h-[600px] w-[600px] rounded-full blur-3xl"
         style="background: radial-gradient(circle, rgba(185,28,28,0.45), transparent 70%);"></div>
  </div>

  <div class="relative h-full flex flex-col items-center justify-center px-6">
    <div class="text-[11px] uppercase tracking-[0.3em] text-accent-400 font-semibold">Locked in</div>
    <div data-ft-lock-mode class="mt-1 text-sm text-ink-400">Lock in Twin🥀 · cycle <span data-ft-lock-cycle class="text-white font-semibold">1</span></div>

    <div data-ft-lock-time
         class="mt-8 font-serif text-[120px] sm:text-[160px] md:text-[200px] font-semibold tabular-nums leading-none gradient-text">
      25:00
    </div>

    <div class="mt-10 flex flex-col items-center gap-4 max-w-md">
      <div class="text-xs text-ink-400 text-center">
        Tabbed away: <span data-ft-lock-blurs class="text-rose-400 font-semibold tabular-nums">0</span>
        <span class="opacity-50 mx-2">·</span>
        Wake lock: <span data-ft-lock-wake class="text-emerald-400 font-semibold">checking…</span>
      </div>

      <button data-ft-lock-end type="button"
        class="relative overflow-hidden px-6 py-3 rounded-full border border-ink-700 hover:border-rose-500 text-ink-300 hover:text-rose-400 text-sm font-medium transition-colors min-w-[200px]"
        aria-label="Hold to end early">
        <span data-ft-lock-end-bar class="absolute inset-0 bg-rose-500/30 origin-left transition-transform"
              style="transform: scaleX(0); transition-duration: 200ms;"></span>
        <span class="relative z-10">Hold to end early</span>
      </button>

      <p class="text-[11px] text-ink-500 text-center leading-relaxed">
        Press <kbd class="px-1.5 py-0.5 rounded bg-ink-900 border border-ink-700 text-ink-300 text-[10px]">Esc</kbd>
        to exit fullscreen but stay locked.<br/>
        Hold the button above for 2 seconds to fully stop.
      </p>
    </div>
  </div>
</div>

<script>
  type SavedState = {
    mode: 'Lock in Twin🥀' | 'Short break' | 'Long break';
    cycle: number;
    secondsLeft: number;
    isRunning: boolean;
    lastTickAt: number;     // ms epoch
    visibility: 'expanded' | 'collapsed' | 'hidden';
    lockEnabled: boolean;
    lockEngaged: boolean;
    blurCount: number;
  };

  const STORAGE_KEY = 'ihhs:floating-timer';
  const WORK_LABEL = 'Lock in Twin🥀';
  const HOLD_MS = 2000;

  const init = () => {
    const root = document.getElementById('floating-timer') as HTMLElement | null;
    if (!root || root.dataset.ftReady === '1') return;
    root.dataset.ftReady = '1';
    const conf = JSON.parse(root.dataset.conf || '{}');
    const card = root.querySelector<HTMLElement>('[data-ft-card]')!;
    const pill = root.querySelector<HTMLButtonElement>('[data-ft-pill]')!;
    const show = root.querySelector<HTMLButtonElement>('[data-ft-show]')!;
    const timeEl = root.querySelector<HTMLElement>('[data-ft-time]')!;
    const pillTimeEl = root.querySelector<HTMLElement>('[data-ft-pill-time]')!;
    const modeEl = root.querySelector<HTMLElement>('[data-ft-mode]')!;
    const cycleEl = root.querySelector<HTMLElement>('[data-ft-cycle]')!;
    const toggleBtn = root.querySelector<HTMLButtonElement>('[data-ft-toggle]')!;
    const skipBtn = root.querySelector<HTMLButtonElement>('[data-ft-skip]')!;
    const resetBtn = root.querySelector<HTMLButtonElement>('[data-ft-reset]')!;
    const collapseBtn = root.querySelector<HTMLButtonElement>('[data-ft-collapse]')!;
    const closeBtn = root.querySelector<HTMLButtonElement>('[data-ft-close]')!;
    const lockToggleEl = root.querySelector<HTMLInputElement>('[data-ft-lock-toggle]')!;

    // Lock overlay (sibling to the floating timer, query off document since
    // we're using a fresh root via View Transitions).
    const lockEl = document.querySelector<HTMLElement>('[data-ft-lock]')!;
    const lockTimeEl = lockEl.querySelector<HTMLElement>('[data-ft-lock-time]')!;
    const lockCycleEl = lockEl.querySelector<HTMLElement>('[data-ft-lock-cycle]')!;
    const lockBlursEl = lockEl.querySelector<HTMLElement>('[data-ft-lock-blurs]')!;
    const lockWakeEl = lockEl.querySelector<HTMLElement>('[data-ft-lock-wake]')!;
    const lockEndBtn = lockEl.querySelector<HTMLButtonElement>('[data-ft-lock-end]')!;
    const lockEndBar = lockEl.querySelector<HTMLElement>('[data-ft-lock-end-bar]')!;

    const fmt = (s: number) => {
      const sec = Math.max(0, Math.floor(s));
      return `${String(Math.floor(sec / 60)).padStart(2, '0')}:${String(sec % 60).padStart(2, '0')}`;
    };

    const load = (): SavedState => {
      try {
        const raw = sessionStorage.getItem(STORAGE_KEY);
        if (raw) {
          const parsed = JSON.parse(raw);
          // Backfill new fields if loading old saved state.
          parsed.lockEnabled = parsed.lockEnabled ?? true;
          parsed.lockEngaged = parsed.lockEngaged ?? false;
          parsed.blurCount = parsed.blurCount ?? 0;
          return parsed;
        }
      } catch {}
      return {
        mode: WORK_LABEL,
        cycle: 1,
        secondsLeft: conf.workMin * 60,
        isRunning: false,
        lastTickAt: Date.now(),
        visibility: 'expanded',
        lockEnabled: true,
        lockEngaged: false,
        blurCount: 0,
      };
    };
    const save = (s: SavedState) => {
      try { sessionStorage.setItem(STORAGE_KEY, JSON.stringify(s)); } catch {}
    };

    let state = load();
    let interval: ReturnType<typeof setInterval> | null = null;
    let wakeLock: any = null;

    if (state.isRunning) {
      const elapsed = (Date.now() - state.lastTickAt) / 1000;
      state.secondsLeft = Math.max(0, state.secondsLeft - elapsed);
    }
    lockToggleEl.checked = state.lockEnabled;

    const setVisibility = (v: SavedState['visibility']) => {
      state.visibility = v;
      card.classList.toggle('hidden', v !== 'expanded');
      pill.classList.toggle('hidden', v !== 'collapsed');
      pill.classList.toggle('flex', v === 'collapsed');
      show.classList.toggle('hidden', v !== 'hidden');
      show.classList.toggle('grid', v === 'hidden');
      save(state);
    };

    const renderLock = () => {
      lockTimeEl.textContent = fmt(state.secondsLeft);
      lockCycleEl.textContent = String(state.cycle);
      lockBlursEl.textContent = String(state.blurCount);
    };

    const render = () => {
      const t = fmt(state.secondsLeft);
      timeEl.textContent = t;
      pillTimeEl.textContent = t;
      modeEl.textContent = state.mode;
      cycleEl.textContent = String(state.cycle);
      toggleBtn.textContent = state.isRunning ? 'Pause' : (state.secondsLeft < secondsForMode(state.mode) ? 'Resume' : 'Start');
      if (state.lockEngaged) renderLock();
    };

    const secondsForMode = (m: string) => m === WORK_LABEL ? conf.workMin * 60 : m === 'Long break' ? conf.longBreakMin * 60 : conf.shortBreakMin * 60;

    const beep = () => {
      try {
        const Ctx = (window as any).AudioContext || (window as any).webkitAudioContext;
        if (!Ctx) return;
        const ctx = new Ctx();
        const osc = ctx.createOscillator();
        const gain = ctx.createGain();
        osc.connect(gain); gain.connect(ctx.destination);
        osc.frequency.value = 880;
        gain.gain.setValueAtTime(0.2, ctx.currentTime);
        gain.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + 0.5);
        osc.start();
        osc.stop(ctx.currentTime + 0.5);
      } catch {}
    };

    /* ---------- Lock-in (fullscreen + wake lock + tab tracking) ---------- */
    const requestWakeLock = async () => {
      try {
        const nav = navigator as any;
        if (nav.wakeLock?.request) {
          wakeLock = await nav.wakeLock.request('screen');
          lockWakeEl.textContent = 'on';
          lockWakeEl.classList.remove('text-rose-400'); lockWakeEl.classList.add('text-emerald-400');
          wakeLock.addEventListener?.('release', () => {
            lockWakeEl.textContent = 'released';
          });
        } else {
          lockWakeEl.textContent = 'unsupported';
          lockWakeEl.classList.remove('text-emerald-400'); lockWakeEl.classList.add('text-rose-400');
        }
      } catch {
        lockWakeEl.textContent = 'denied';
        lockWakeEl.classList.remove('text-emerald-400'); lockWakeEl.classList.add('text-rose-400');
      }
    };
    const releaseWakeLock = async () => {
      try { if (wakeLock) { await wakeLock.release(); } } catch {}
      wakeLock = null;
    };

    const engageLock = async () => {
      state.lockEngaged = true;
      lockEl.classList.remove('hidden');
      renderLock();
      try { if (!document.fullscreenElement) await document.documentElement.requestFullscreen(); } catch {}
      requestWakeLock();
      save(state);
    };
    const releaseLock = async () => {
      state.lockEngaged = false;
      lockEl.classList.add('hidden');
      try { if (document.fullscreenElement) await document.exitFullscreen(); } catch {}
      releaseWakeLock();
      save(state);
    };

    // Track tab/window blurs while locked. If they tab away, increment.
    const onVisibility = async () => {
      if (!state.lockEngaged) return;
      if (document.visibilityState === 'hidden') {
        state.blurCount++;
        renderLock();
        save(state);
      } else if (document.visibilityState === 'visible' && !wakeLock) {
        // Browsers auto-release wake lock when tab is hidden; re-acquire.
        requestWakeLock();
      }
    };
    document.addEventListener('visibilitychange', onVisibility);

    /* ---------- Hold-to-end ---------- */
    let holdTimer: number | null = null;
    const beginHold = (e: Event) => {
      e.preventDefault();
      lockEndBar.style.transitionDuration = `${HOLD_MS}ms`;
      lockEndBar.style.transform = 'scaleX(1)';
      holdTimer = window.setTimeout(() => { stop(); }, HOLD_MS);
    };
    const cancelHold = () => {
      if (holdTimer != null) { clearTimeout(holdTimer); holdTimer = null; }
      lockEndBar.style.transitionDuration = '180ms';
      lockEndBar.style.transform = 'scaleX(0)';
    };
    lockEndBtn.addEventListener('mousedown', beginHold);
    lockEndBtn.addEventListener('touchstart', beginHold, { passive: false });
    lockEndBtn.addEventListener('mouseup', cancelHold);
    lockEndBtn.addEventListener('mouseleave', cancelHold);
    lockEndBtn.addEventListener('touchend', cancelHold);
    lockEndBtn.addEventListener('touchcancel', cancelHold);
    lockEndBtn.addEventListener('blur', cancelHold);

    /* ---------- Timer engine ---------- */
    const advance = () => {
      if (state.mode === WORK_LABEL) {
        state.mode = state.cycle % conf.cyclesUntilLong === 0 ? 'Long break' : 'Short break';
      } else {
        state.cycle++;
        state.mode = WORK_LABEL;
      }
      state.secondsLeft = secondsForMode(state.mode);
    };

    const tick = () => {
      const now = Date.now();
      const elapsed = (now - state.lastTickAt) / 1000;
      state.lastTickAt = now;
      state.secondsLeft -= elapsed;
      if (state.secondsLeft <= 0) {
        const wasWork = state.mode === WORK_LABEL;
        stop();
        beep();
        advance();
        // Don't auto-engage lock during a break; it's relax time.
        if (!wasWork) { /* break ended; user clicks Start to lock in next work block */ }
      }
      render();
      save(state);
    };

    const start = async () => {
      if (interval) return;
      state.isRunning = true;
      state.lastTickAt = Date.now();
      state.blurCount = 0;
      interval = setInterval(tick, 1000);
      // Engage lock only for work sessions, only if user opted in.
      if (state.lockEnabled && state.mode === WORK_LABEL) {
        await engageLock();
      }
      render(); save(state);
    };

    const stop = async () => {
      if (interval) { clearInterval(interval); interval = null; }
      state.isRunning = false;
      if (state.lockEngaged) await releaseLock();
      render(); save(state);
    };

    toggleBtn.addEventListener('click', () => state.isRunning ? stop() : start());
    skipBtn.addEventListener('click', async () => { await stop(); advance(); render(); save(state); });
    resetBtn.addEventListener('click', async () => {
      await stop();
      state.cycle = 1;
      state.mode = WORK_LABEL;
      state.secondsLeft = conf.workMin * 60;
      state.blurCount = 0;
      render(); save(state);
    });
    collapseBtn.addEventListener('click', () => setVisibility('collapsed'));
    closeBtn.addEventListener('click', async () => { await stop(); setVisibility('hidden'); });
    pill.addEventListener('click', () => setVisibility('expanded'));
    show.addEventListener('click', () => setVisibility('expanded'));
    lockToggleEl.addEventListener('change', () => {
      state.lockEnabled = lockToggleEl.checked;
      save(state);
    });

    setVisibility(state.visibility);
    render();
    if (state.isRunning) {
      // Re-arm the interval after navigation.
      interval = setInterval(tick, 1000);
      // Re-show the overlay if we were locked, but DON'T try to re-enter
      // fullscreen (browsers require a user gesture for that). User can
      // press F11 / re-enter manually if they want.
      if (state.lockEngaged && state.lockEnabled && state.mode === WORK_LABEL) {
        lockEl.classList.remove('hidden');
        renderLock();
        requestWakeLock();
      }
    }
  };
  init();
  document.addEventListener('astro:after-swap', init);
</script>
