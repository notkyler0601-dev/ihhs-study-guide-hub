---
// Before/after image slider using img-comparison-slider (web component).
interface Props {
  before: string;
  after: string;
  beforeLabel?: string;
  afterLabel?: string;
  title?: string;
  height?: number;
}
const { before, after, beforeLabel = 'Before', afterLabel = 'After', title, height = 420 } = Astro.props;
---

<figure class="not-prose my-8 surface rounded-2xl overflow-hidden shadow-soft">
  {title && (
    <figcaption class="px-5 py-3 border-b border-ink-200 dark:border-ink-800 font-serif text-base font-semibold">{title}</figcaption>
  )}
  <img-comparison-slider class="w-full bg-ink-100 dark:bg-ink-900" style={`--divider-color:#b91c1c; --divider-width:2px; height:${height}px; display:block;`}>
    <img slot="first" src={before} alt={beforeLabel} class="w-full h-full object-cover"/>
    <img slot="second" src={after} alt={afterLabel} class="w-full h-full object-cover"/>
    <span slot="first-label" class="absolute top-3 left-3 px-2 py-1 rounded-md bg-black/60 text-white text-xs font-medium">{beforeLabel}</span>
    <span slot="second-label" class="absolute top-3 right-3 px-2 py-1 rounded-md bg-black/60 text-white text-xs font-medium">{afterLabel}</span>
  </img-comparison-slider>
</figure>

<script>
  import { loadScript, loadStyle } from '../lib/loadScript';
  const init = async () => {
    loadStyle('https://unpkg.com/img-comparison-slider@8.0.6/dist/styles.css');
    await loadScript('https://unpkg.com/img-comparison-slider@8.0.6/dist/index.js', { module: true });
  };
  init();
  document.addEventListener('astro:after-swap', init);
</script>
