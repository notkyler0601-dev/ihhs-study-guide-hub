---
// Ear training exercises embedded from ToneDear.
interface Props {
  title?: string;
  exercise?: 'intervals' | 'chords' | 'scales' | 'progressions';
  height?: number;
}
const { title = 'Ear training', exercise = 'intervals', height = 560 } = Astro.props;
const urls: Record<string, string> = {
  intervals:    'https://tonedear.com/ear-training/intervals',
  chords:       'https://tonedear.com/ear-training/chord-identification',
  scales:       'https://tonedear.com/ear-training/scale-identification',
  progressions: 'https://tonedear.com/ear-training/chord-progressions',
};
const url = urls[exercise] ?? urls.intervals;
---

<figure class="not-prose my-8 surface rounded-2xl overflow-hidden shadow-soft">
  <figcaption class="px-5 py-3 border-b border-ink-200 dark:border-ink-800 flex items-center justify-between gap-3">
    <span class="font-serif text-base font-semibold capitalize">{title}, {exercise}</span>
    <span class="text-[10px] uppercase tracking-[0.16em] text-ink-500 font-semibold">ToneDear</span>
  </figcaption>
  <div class="relative w-full bg-ink-100 dark:bg-ink-800" style={`height:${height}px`}>
    <iframe src={url} title={title} class="absolute inset-0 w-full h-full" loading="lazy"></iframe>
  </div>
</figure>
