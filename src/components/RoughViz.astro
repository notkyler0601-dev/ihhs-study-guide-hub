---
// Hand-drawn aesthetic charts via rough-viz. type: 'bar', 'horizontalBar',
// 'line', 'pie', 'donut', 'scatter', 'stackedBar'.
interface Props {
  title?: string;
  type?: 'bar' | 'horizontalBar' | 'line' | 'pie' | 'donut' | 'scatter' | 'stackedBar';
  labels: string[];
  values: number[];
  yLabel?: string;
  height?: number;
}
const { title = 'Chart', type = 'bar', labels, values, yLabel = 'Value', height = 360 } = Astro.props;
const id = 'rv-' + Math.random().toString(36).slice(2, 9);
const conf = JSON.stringify({ type, labels, values, yLabel });
---

<figure class="not-prose my-8 surface rounded-2xl shadow-soft p-5" id={id} data-rv data-conf={conf}>
  <figcaption class="mb-3 font-serif text-base font-semibold">{title}</figcaption>
  <div data-rv-host class="w-full overflow-x-auto" style={`min-height:${height}px`}></div>
</figure>

<script>
  import { loadScript, waitForGlobal } from '../lib/loadScript';

  const init = async () => {
    const roots = document.querySelectorAll<HTMLElement>('[data-rv]:not([data-rv-ready])');
    if (roots.length === 0) return;
    await loadScript('https://d3js.org/d3.v5.min.js');
    await loadScript('https://unpkg.com/rough-viz@2.0.5');
    const roughViz: any = await waitForGlobal('roughViz');

    roots.forEach((root) => {
      root.dataset.rvReady = '1';
      const host = root.querySelector<HTMLElement>('[data-rv-host]')!;
      host.id = 'rv-host-' + Math.random().toString(36).slice(2, 9);
      const { type, labels, values, yLabel } = JSON.parse(root.dataset.conf || '{}');
      const isDark = document.documentElement.classList.contains('dark');
      const dataObj = { labels, values };
      try {
        const klass = ({
          bar: roughViz.Bar,
          horizontalBar: roughViz.BarH,
          line: roughViz.Line,
          pie: roughViz.Pie,
          donut: roughViz.Donut,
          scatter: roughViz.Scatter,
          stackedBar: roughViz.StackedBar,
        } as any)[type];
        if (!klass) throw new Error('Unknown roughViz type ' + type);
        new klass({
          element: '#' + host.id,
          data: dataObj,
          title: '',
          yLabel,
          color: '#b91c1c',
          fillStyle: 'cross-hatch',
          fillWeight: 0.6,
          strokeWidth: 1,
          font: 'Fraunces, serif',
          axisFontSize: '12px',
          labelFontSize: '12px',
          margin: { top: 10, right: 20, bottom: 50, left: 60 },
        });
        if (isDark) {
          // Recolor axes for dark mode
          setTimeout(() => {
            host.querySelectorAll<SVGTextElement>('text').forEach((t) => (t.style.fill = '#fafafa'));
            host.querySelectorAll<SVGPathElement>('path.domain, line').forEach((p) => (p.style.stroke = '#a1a1aa'));
          }, 100);
        }
      } catch (e) {
        console.warn('RoughViz failed', e);
      }
    });
  };
  init();
  document.addEventListener('astro:after-swap', init);
</script>
