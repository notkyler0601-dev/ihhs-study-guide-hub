---
// Gantt chart for project timelines and parallel historical events.
// Powered by Frappe Gantt. Each task: { id, name, start, end, progress?, dependencies? }
interface Task {
  id: string;
  name: string;
  start: string;       // YYYY-MM-DD
  end: string;
  progress?: number;   // 0-100
  dependencies?: string;
}
interface Props {
  title?: string;
  tasks: Task[];
  viewMode?: 'Quarter Day' | 'Half Day' | 'Day' | 'Week' | 'Month';
  height?: number;
}
const { title = 'Timeline', tasks, viewMode = 'Day', height = 440 } = Astro.props;
const id = 'gantt-' + Math.random().toString(36).slice(2, 9);
const conf = JSON.stringify({ tasks, viewMode });
---

<figure class="not-prose my-8 surface rounded-2xl p-5 shadow-soft" id={id} data-gantt data-conf={conf}>
  <figcaption class="mb-3 font-serif text-base font-semibold">{title}</figcaption>
  <div data-gantt-host class="w-full overflow-x-auto" style={`max-height:${height}px`}></div>
</figure>

<style>
  [data-gantt-host] .gantt .bar { fill: theme('colors.accent.600'); }
  [data-gantt-host] .gantt .bar-progress { fill: theme('colors.accent.800'); }
  [data-gantt-host] .gantt .bar-label { fill: #fff; font-family: 'Inter', sans-serif; }
  .dark [data-gantt-host] .gantt .bar { fill: theme('colors.accent.500'); }
  .dark [data-gantt-host] .gantt .bar-progress { fill: theme('colors.accent.300'); }
</style>

<script>
  import { loadScript, loadStyle, waitForGlobal } from '../lib/loadScript';

  const init = async () => {
    const roots = document.querySelectorAll<HTMLElement>('[data-gantt]:not([data-gantt-ready])');
    if (roots.length === 0) return;

    loadStyle('https://cdn.jsdelivr.net/npm/frappe-gantt@0.9.2/dist/frappe-gantt.min.css');
    await loadScript('https://cdn.jsdelivr.net/npm/frappe-gantt@0.9.2/dist/frappe-gantt.min.js');
    const Gantt: any = await waitForGlobal('Gantt');

    roots.forEach((root) => {
      root.dataset.ganttReady = '1';
      const host = root.querySelector<HTMLElement>('[data-gantt-host]')!;
      host.id = 'g-' + Math.random().toString(36).slice(2, 9);
      const svg = document.createElement('svg');
      host.appendChild(svg);
      const conf = JSON.parse(root.dataset.conf || '{}');
      try {
        new Gantt(svg, conf.tasks ?? [], {
          view_mode: conf.viewMode ?? 'Day',
          bar_height: 22,
          bar_corner_radius: 3,
          padding: 16,
          language: 'en',
        });
      } catch (e) {
        console.warn('GanttChart render failed', e);
      }
    });
  };
  init();
  document.addEventListener('astro:after-swap', init);
</script>
