---
// Render and play sheet music from ABC notation using abcjs.
// ABC notation cheatsheet: https://abcnotation.com/learn
interface Props {
  abc: string;
  title?: string;
  playable?: boolean;
}
const { abc, title, playable = true } = Astro.props;
const id = 'abc-' + Math.random().toString(36).slice(2, 9);
---

<figure class="not-prose my-6 surface rounded-2xl p-5 shadow-soft" id={id} data-abc>
  {title && <figcaption class="mb-3 font-serif text-base font-semibold">{title}</figcaption>}
  <div data-abc-notation class="bg-white rounded-md p-2 overflow-x-auto"></div>
  {playable && (
    <div data-abc-audio class="mt-3"></div>
  )}
  <script type="application/x-abc" data-abc-src set:html={abc} />
</figure>

<script>
  import { importGlobal, loadStyle } from '../lib/loadScript';

  const init = async () => {
    const roots = document.querySelectorAll<HTMLElement>('[data-abc]:not([data-abc-ready])');
    if (roots.length === 0) return;

    loadStyle('https://cdn.jsdelivr.net/npm/abcjs@6.4.4/abcjs-audio.css');
    const ABCJS: any = await importGlobal(
      'https://cdn.jsdelivr.net/npm/abcjs@6.4.4/dist/abcjs-basic-min.js',
      'ABCJS'
    );

    roots.forEach((root) => {
      root.dataset.abcReady = '1';
      const notation = root.querySelector<HTMLElement>('[data-abc-notation]')!;
      const srcEl = root.querySelector<HTMLElement>('[data-abc-src]');
      const audioHost = root.querySelector<HTMLElement>('[data-abc-audio]');
      const abc = srcEl?.textContent ?? '';
      const visualObj = ABCJS.renderAbc(notation, abc, { responsive: 'resize' })[0];

      if (audioHost && ABCJS.synth?.supportsAudio()) {
        const synthControl = new ABCJS.synth.SynthController();
        synthControl.load(audioHost, null, { displayLoop: true, displayRestart: true, displayPlay: true, displayProgress: true });
        const createSynth = new ABCJS.synth.CreateSynth();
        createSynth.init({ visualObj }).then(() => {
          synthControl.setTune(visualObj, false).catch((e: unknown) => console.warn('Score audio init failed', e));
        });
      }
    });
  };
  init();
  document.addEventListener('astro:after-swap', init);
</script>
