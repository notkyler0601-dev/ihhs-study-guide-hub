---
// Digital logic simulator via CircuitVerse iframe embed. For a shareable
// circuit, set `circuitId` to the id from a CircuitVerse project share link.
interface Props {
  title?: string;
  circuitId?: string;
  height?: number;
}
const { title = 'Digital logic circuit', circuitId, height = 540 } = Astro.props;
const url = circuitId
  ? `https://circuitverse.org/simulator/embed/${circuitId}`
  : 'https://circuitverse.org/simulator/';
---

<figure class="not-prose my-8 surface rounded-2xl overflow-hidden shadow-soft">
  <figcaption class="px-5 py-3 border-b border-ink-200 dark:border-ink-800 flex items-center justify-between gap-3">
    <span class="font-serif text-base font-semibold">{title}</span>
    <span class="text-[10px] uppercase tracking-[0.16em] text-ink-500 font-semibold">CircuitVerse</span>
  </figcaption>
  <div class="relative w-full bg-ink-100 dark:bg-ink-800" style={`height:${height}px`}>
    <iframe src={url} title={title} class="absolute inset-0 w-full h-full" loading="lazy" allowfullscreen></iframe>
  </div>
</figure>
