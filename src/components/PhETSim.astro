---
// Embed a PhET Interactive Simulation by simulation id.
// Find sim ids at https://phet.colorado.edu/en/simulations/filter?subjects=physics&type=html
// e.g. "projectile-motion", "circuit-construction-kit-dc", "balloons-and-static-electricity"
interface Props {
  sim: string;
  title?: string;
  height?: number;
  locale?: string;
}
const { sim, title, height = 600, locale = 'en' } = Astro.props;
const url = `https://phet.colorado.edu/sims/html/${sim}/latest/${sim}_${locale}.html`;
---

<figure class="not-prose my-8 surface rounded-2xl overflow-hidden shadow-soft">
  {title && (
    <figcaption class="px-5 py-3 border-b border-ink-200 dark:border-ink-800 flex items-center justify-between gap-3">
      <span class="font-serif text-base font-semibold">{title}</span>
      <span class="text-[10px] uppercase tracking-[0.16em] text-ink-500 font-semibold">PhET Sim</span>
    </figcaption>
  )}
  <div class="relative w-full bg-ink-100 dark:bg-ink-800" style={`height:${height}px`}>
    <iframe
      src={url}
      title={title ?? `PhET: ${sim}`}
      class="absolute inset-0 w-full h-full"
      loading="lazy"
      allowfullscreen
    ></iframe>
  </div>
  <div class="px-5 py-2 text-[11px] text-ink-500 dark:text-ink-400 border-t border-ink-200 dark:border-ink-800">
    Sim by <a href={`https://phet.colorado.edu/en/simulation/${sim}`} class="text-accent-700 dark:text-accent-400 hover:underline" target="_blank" rel="noopener">PhET, University of Colorado Boulder</a>
  </div>
</figure>
