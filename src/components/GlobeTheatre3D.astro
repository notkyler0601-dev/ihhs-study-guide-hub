---
// Interactive 3D model of an Elizabethan playhouse.
// Primary: react-three-fiber Canvas (renders only with JS).
// Fallback: the static SVG with the same hotspots, shown when printing or when JS is off.
//
// Usage:
//   <GlobeTheatre3D
//     fallbackImage="/globe-theatre.svg"
//     hotspots={[
//       { id: "balcony", label: "Upper acting space", description: "...", position: [0, 2.7, -2.6], flat: { x: 50, y: 47 } },
//     ]}
//   />
import GlobeTheatre3DReact from './react/GlobeTheatre3D.tsx';

interface Hotspot {
  id: string;
  label: string;
  description: string;
  position: [number, number, number];
  flat: { x: number; y: number };
}
interface Props {
  title?: string;
  height?: number;
  fallbackImage: string;
  fallbackAlt?: string;
  hotspots: Hotspot[];
}
const {
  title = 'Inside the Globe Theatre',
  height = 540,
  fallbackImage,
  fallbackAlt = 'Cross-section of an Elizabethan playhouse.',
  hotspots,
} = Astro.props;

const conf = JSON.stringify({ spots: hotspots.map((h) => ({ x: h.flat.x, y: h.flat.y, label: h.label, description: h.description })), mode: 'reveal' });
const fid = 'fb-' + Math.random().toString(36).slice(2, 9);
---

<figure class="not-prose my-8 surface rounded-2xl shadow-soft overflow-hidden">
  <figcaption class="px-5 py-3 border-b border-ink-200 dark:border-ink-800 flex items-center justify-between gap-3">
    <span class="font-serif text-base font-semibold">{title}</span>
    <span class="text-[10px] uppercase tracking-[0.16em] text-ink-500 font-semibold">interactive 3D</span>
  </figcaption>

  {/* Primary: 3D viewer. Hidden when printing. */}
  <div class="globe3d-primary print:hidden">
    <GlobeTheatre3DReact
      client:only="react"
      height={height}
      hotspots={hotspots.map((h) => ({ id: h.id, label: h.label, description: h.description, position: h.position }))}
    />
  </div>

  {/* Fallback: SVG with clickable hotspots. Shown for printing AND for users with JS off. */}
  <figure
    id={fid}
    data-hot
    data-conf={conf}
    class="globe3d-fallback hidden print:block m-0"
  >
    <div class="relative bg-ink-100 dark:bg-ink-800">
      <img src={fallbackImage} alt={fallbackAlt} class="block w-full h-auto" />
      <div data-hot-overlay class="absolute inset-0"></div>
    </div>
    <div data-hot-info class="px-5 py-3 border-t border-ink-200 dark:border-ink-800 text-sm min-h-[40px] text-ink-600 dark:text-ink-300"></div>
  </figure>

  {/* If JS is disabled, force the fallback to be visible via inline style override. */}
  <noscript>
    <style>{`#${fid}.globe3d-fallback { display: block !important; }`}</style>
  </noscript>
</figure>

<script>
  // Reuse the Hotspots reveal/quiz logic so the SVG fallback is interactive
  // when shown (in print mode the JS won't run, but reveal-on-hover still
  // produces a sensible static page; in no-JS mode none of this fires and
  // the user just sees the labelled image).
  interface Spot { x: number; y: number; label: string; description?: string; }
  interface Conf { spots: Spot[]; mode: 'reveal' | 'quiz'; }

  const init = () => {
    document.querySelectorAll<HTMLElement>('.globe3d-fallback[data-hot]:not([data-hot-ready])').forEach((root) => {
      root.dataset.hotReady = '1';
      const conf: Conf = JSON.parse(root.dataset.conf || '{}');
      const overlay = root.querySelector<HTMLElement>('[data-hot-overlay]')!;
      const info = root.querySelector<HTMLElement>('[data-hot-info]')!;
      conf.spots.forEach((s) => {
        const dot = document.createElement('button');
        dot.type = 'button';
        dot.className = 'absolute w-6 h-6 -translate-x-1/2 -translate-y-1/2 rounded-full border-2 border-white bg-accent-700 hover:bg-accent-500 hover:scale-110 transition-transform shadow-lift';
        dot.style.left = s.x + '%';
        dot.style.top = s.y + '%';
        dot.title = s.label;
        dot.setAttribute('aria-label', s.label);
        dot.addEventListener('click', () => {
          info.innerHTML = `<strong class="text-ink-900 dark:text-ink-100">${s.label}.</strong> ${s.description ?? ''}`;
        });
        overlay.appendChild(dot);
      });
    });
  };
  init();
  document.addEventListener('astro:after-swap', init);
</script>
