---
interface Props { question: string; }
const { question } = Astro.props;
---

<details class="not-prose group my-4 rounded-xl border border-ink-200 dark:border-ink-800 bg-white dark:bg-ink-900 overflow-hidden transition-all hover:border-accent-300 dark:hover:border-accent-700">
  <summary class="flex items-start justify-between gap-3 cursor-pointer select-none px-5 py-4 list-none">
    <div class="flex items-start gap-3 flex-1">
      <span class="mt-0.5 inline-flex items-center justify-center h-6 w-6 rounded-md bg-accent-100 dark:bg-accent-900/40 text-accent-700 dark:text-accent-300 text-xs font-semibold font-mono">Q</span>
      <span class="font-medium text-ink-900 dark:text-ink-100 text-pretty">{question}</span>
    </div>
    <svg class="h-5 w-5 shrink-0 text-ink-400 transition-transform group-open:rotate-180" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
      <path d="m6 9 6 6 6-6"/>
    </svg>
  </summary>
  <div class="px-5 pb-5 pt-2 ml-9 text-ink-700 dark:text-ink-300 leading-relaxed border-t border-dashed border-ink-200 dark:border-ink-800 pt-4 -mt-1">
    <slot />
  </div>
</details>
