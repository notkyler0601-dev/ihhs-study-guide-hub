---
// Lecture video with timestamped annotations. Clicking an annotation in
// the list jumps the video to that time. Annotations are baked in at
// author time (no live commenting yet).
interface Annotation { t: number; label: string; note?: string; }
interface Props {
  title?: string;
  src: string;
  poster?: string;
  annotations?: Annotation[];
  height?: number;
}
const { title, src, poster, annotations = [], height = 400 } = Astro.props;
const id = 'vid-' + Math.random().toString(36).slice(2, 9);

const fmtTime = (s: number) => {
  const m = Math.floor(s / 60);
  const sec = Math.floor(s % 60).toString().padStart(2, '0');
  return `${m}:${sec}`;
};
---

<figure class="not-prose my-8 surface rounded-2xl p-5 shadow-soft" id={id} data-vid>
  {title && <figcaption class="mb-3 font-serif text-base font-semibold">{title}</figcaption>}
  <div class="grid lg:grid-cols-[minmax(0,2fr)_minmax(0,1fr)] gap-5">
    <div class="relative w-full bg-black rounded-md overflow-hidden" style={`min-height:${height}px`}>
      <video data-vid-player controls preload="metadata" class="w-full h-full" style={`max-height:${height}px`} poster={poster}>
        <source src={src} />
      </video>
      <!-- Timeline track showing annotation markers -->
      <div data-vid-track class="absolute left-0 right-0 bottom-14 h-1 pointer-events-none"></div>
    </div>
    <ol class="space-y-2 max-h-[420px] overflow-y-auto scrollbar-thin">
      {annotations.map((a, i) => (
        <li>
          <button
            data-vid-jump={a.t}
            type="button"
            class="w-full text-left surface rounded-lg px-3 py-2 hover:border-accent-400 dark:hover:border-accent-600 transition-colors"
          >
            <div class="flex items-center gap-2 text-xs text-accent-700 dark:text-accent-400 font-mono mb-0.5">
              <span class="inline-block w-6 h-4 rounded bg-accent-700 dark:bg-accent-500 text-white text-center leading-4">{i + 1}</span>
              {fmtTime(a.t)}
            </div>
            <div class="text-sm font-medium">{a.label}</div>
            {a.note && <div class="text-xs text-ink-500 dark:text-ink-400 mt-1">{a.note}</div>}
          </button>
        </li>
      ))}
    </ol>
  </div>
</figure>

<script>
  const init = () => {
    document.querySelectorAll<HTMLElement>('[data-vid]:not([data-vid-ready])').forEach((root) => {
      root.dataset.vidReady = '1';
      const player = root.querySelector<HTMLVideoElement>('[data-vid-player]');
      const track = root.querySelector<HTMLElement>('[data-vid-track]');
      if (!player) return;

      root.querySelectorAll<HTMLButtonElement>('[data-vid-jump]').forEach((btn) => {
        btn.addEventListener('click', () => {
          const t = Number(btn.getAttribute('data-vid-jump'));
          player.currentTime = t;
          void player.play();
        });
      });

      // Render markers on the custom track once metadata loads.
      player.addEventListener('loadedmetadata', () => {
        if (!track) return;
        const dur = player.duration || 0;
        if (!dur) return;
        track.innerHTML = '';
        root.querySelectorAll<HTMLButtonElement>('[data-vid-jump]').forEach((btn) => {
          const t = Number(btn.getAttribute('data-vid-jump'));
          const mark = document.createElement('div');
          mark.style.cssText = `position:absolute; left:${(t/dur)*100}%; top:-2px; width:4px; height:8px; background:#b91c1c; border-radius:1px;`;
          track.appendChild(mark);
        });
      });
    });
  };
  init();
  document.addEventListener('astro:after-swap', init);
</script>
