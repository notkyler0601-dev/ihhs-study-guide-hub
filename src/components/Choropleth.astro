---
// Color regions of a map by data value. Defaults to US states; pass `geoUrl`
// for a different topojson (countries, counties, custom regions).
// data: { [regionId]: number }, where regionId matches the topojson feature id.
interface Props {
  title?: string;
  data: Record<string, number>;
  geoUrl?: string;
  objectName?: string;
  height?: number;
  legendLabel?: string;
}
const {
  title = 'Choropleth',
  data,
  geoUrl = 'https://cdn.jsdelivr.net/npm/us-atlas@3.0.1/states-10m.json',
  objectName = 'states',
  height = 460,
  legendLabel = 'Value',
} = Astro.props;
const id = 'cp-' + Math.random().toString(36).slice(2, 9);
const conf = JSON.stringify({ data, geoUrl, objectName, legendLabel });
---

<figure class="not-prose my-8 surface rounded-2xl shadow-soft p-5" id={id} data-cp data-conf={conf}>
  <figcaption class="mb-3 font-serif text-base font-semibold">{title}</figcaption>
  <div data-cp-host class="w-full" style={`min-height:${height}px`}></div>
</figure>

<script>
  const init = async () => {
    const roots = document.querySelectorAll<HTMLElement>('[data-cp]:not([data-cp-ready])');
    if (roots.length === 0) return;
    let d3: any, topojson: any;
    try {
      d3 = await import(/* @vite-ignore */ 'https://cdn.jsdelivr.net/npm/d3@7/+esm');
      topojson = await import(/* @vite-ignore */ 'https://cdn.jsdelivr.net/npm/topojson-client@3.1.0/+esm');
    } catch (e) { console.warn('Choropleth deps failed', e); return; }

    for (const root of roots) {
      root.dataset.cpReady = '1';
      const host = root.querySelector<HTMLElement>('[data-cp-host]')!;
      const conf = JSON.parse(root.dataset.conf || '{}');
      try {
        const topo = await fetch(conf.geoUrl).then((r) => r.json());
        const features = topojson.feature(topo, topo.objects[conf.objectName]).features;
        const w = host.clientWidth || 720;
        const h = 460;
        const path = d3.geoPath(d3.geoIdentity().reflectY(true).fitSize([w, h], { type: 'FeatureCollection', features }));

        const values = Object.values(conf.data) as number[];
        const max = Math.max(...values, 1);
        const min = Math.min(...values, 0);
        const color = d3.scaleSequential([min, max], d3.interpolate('#fee2e2', '#7f1d1d'));

        const svg = d3.select(host).append('svg').attr('viewBox', `0 0 ${w} ${h + 40}`).attr('width', w).attr('height', h + 40);
        svg.append('g').selectAll('path').data(features).join('path')
          .attr('d', path)
          .attr('fill', (d: any) => {
            const v = conf.data[String(d.id)];
            return v != null ? color(v) : '#e4e4e7';
          })
          .attr('stroke', '#fff').attr('stroke-width', 0.5)
          .append('title').text((d: any) => `${d.properties?.name ?? d.id}: ${conf.data[String(d.id)] ?? 'no data'}`);

        // Legend
        const lg = svg.append('g').attr('transform', `translate(${w - 220},${h + 10})`);
        const grad = svg.append('defs').append('linearGradient').attr('id', root.id + '-grad');
        grad.append('stop').attr('offset', '0%').attr('stop-color', '#fee2e2');
        grad.append('stop').attr('offset', '100%').attr('stop-color', '#7f1d1d');
        lg.append('rect').attr('width', 200).attr('height', 10).attr('fill', `url(#${root.id}-grad)`);
        lg.append('text').attr('x', 0).attr('y', 28).attr('font-size', 10).attr('font-family', 'Inter, sans-serif').attr('fill', 'currentColor').text(`${conf.legendLabel}: ${min}`);
        lg.append('text').attr('x', 200).attr('y', 28).attr('text-anchor', 'end').attr('font-size', 10).attr('font-family', 'Inter, sans-serif').attr('fill', 'currentColor').text(String(max));
      } catch (e) {
        console.warn('Choropleth failed', e);
      }
    }
  };
  init();
  document.addEventListener('astro:after-swap', init);
</script>
