---
// Animated stroke-order tutor for Chinese/Japanese characters.
interface Props {
  character: string;
  title?: string;
  size?: number;
}
const { character, title, size = 200 } = Astro.props;
const id = 'hanzi-' + Math.random().toString(36).slice(2, 9);
---

<figure class="not-prose my-6 surface rounded-2xl p-5 shadow-soft text-center" id={id} data-hanzi data-character={character} data-size={size}>
  {title && <figcaption class="mb-3 font-serif text-base font-semibold">{title}</figcaption>}
  <div data-hanzi-target class="mx-auto" style={`width:${size}px; height:${size}px`}></div>
  <div class="mt-3 flex items-center justify-center gap-2 text-xs">
    <button data-hanzi-animate type="button" class="px-3 py-1 rounded-md bg-accent-700 hover:bg-accent-800 text-white dark:bg-accent-600 dark:hover:bg-accent-500">Animate</button>
    <button data-hanzi-quiz type="button" class="px-3 py-1 rounded-md bg-ink-100 dark:bg-ink-800 hover:bg-ink-200 dark:hover:bg-ink-700">Practice</button>
    <button data-hanzi-loop type="button" class="px-3 py-1 rounded-md bg-ink-100 dark:bg-ink-800 hover:bg-ink-200 dark:hover:bg-ink-700">Loop</button>
  </div>
</figure>

<script>
  import { importGlobal } from '../lib/loadScript';

  const init = async () => {
    const roots = document.querySelectorAll<HTMLElement>('[data-hanzi]:not([data-hanzi-ready])');
    if (roots.length === 0) return;

    const HanziWriter: any = await importGlobal(
      'https://cdn.jsdelivr.net/npm/hanzi-writer@3.7.2/dist/hanzi-writer.min.js',
      'HanziWriter'
    );

    roots.forEach((root) => {
      root.dataset.hanziReady = '1';
      const host = root.querySelector<HTMLElement>('[data-hanzi-target]')!;
      host.id = 'hwz-' + Math.random().toString(36).slice(2, 9);
      const char = root.dataset.character ?? '';
      const size = Number(root.dataset.size || 200);
      const isDark = document.documentElement.classList.contains('dark');

      const writer = HanziWriter.create(host.id, char, {
        width: size, height: size, padding: 8,
        strokeColor: isDark ? '#fafafa' : '#27272a',
        radicalColor: '#b91c1c',
        highlightColor: '#dc2626',
        outlineColor: isDark ? '#52525b' : '#d4d4d8',
        strokeAnimationSpeed: 1, delayBetweenStrokes: 150,
      });

      root.querySelector('[data-hanzi-animate]')?.addEventListener('click', () => writer.animateCharacter());
      root.querySelector('[data-hanzi-quiz]')?.addEventListener('click', () => writer.quiz({ showHintAfterMisses: 3 }));
      root.querySelector('[data-hanzi-loop]')?.addEventListener('click', () => writer.loopCharacterAnimation());
    });
  };
  init();
  document.addEventListener('astro:after-swap', init);
</script>
