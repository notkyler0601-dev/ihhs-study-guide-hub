---
// Embed the interactive Ptable periodic table by iframe.
// Optional `element` prop deep-links to a specific element page.
interface Props {
  title?: string;
  element?: string;
  height?: number;
}
const { title = 'Periodic table of the elements', element, height = 600 } = Astro.props;
const src = element
  ? `https://ptable.com/?lang=en&name=${encodeURIComponent(element)}`
  : 'https://ptable.com/?lang=en';
---

<figure class="not-prose my-8 surface rounded-2xl overflow-hidden shadow-soft">
  <figcaption class="px-5 py-3 border-b border-ink-200 dark:border-ink-800 flex items-center justify-between gap-3">
    <span class="font-serif text-base font-semibold">{title}</span>
    <span class="text-[10px] uppercase tracking-[0.16em] text-ink-500 font-semibold">Ptable.com</span>
  </figcaption>
  <div class="relative w-full bg-ink-100 dark:bg-ink-800" style={`height:${height}px`}>
    <iframe src={src} title={title} class="absolute inset-0 w-full h-full" loading="lazy" allowfullscreen></iframe>
  </div>
</figure>
