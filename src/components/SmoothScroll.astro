---
// Site-wide smooth scroll via Lenis. Drop into BaseLayout (or any layout) once.
// Preserves keyboard accessibility and Cmd-F search.
//
// Usage in BaseLayout.astro:
//   <SmoothScroll />
---

<script>
  import Lenis from 'lenis';

  let lenis: Lenis | null = null;

  const init = () => {
    if (lenis) lenis.destroy();
    lenis = new Lenis({ duration: 1.0, easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)) });
    const raf = (time: number) => { lenis?.raf(time); requestAnimationFrame(raf); };
    requestAnimationFrame(raf);
  };
  init();
  document.addEventListener('astro:after-swap', init);
</script>
