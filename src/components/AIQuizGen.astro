---
// <AIQuizGen>
//
// One-click "generate fresh practice questions from this guide" button.
// Uses WebLLM (loaded on demand). Asks the model for JSON, parses it, then
// renders the questions with the same look + interactivity as <Quiz>.
//
// Usage in MDX:
//   import AIQuizGen from '../../components/AIQuizGen.astro';
//   <AIQuizGen count={5} />
//
// Props:
//   - count?: number of questions to generate (default 5)
//   - title?: header (default "Generate fresh practice")
//   - subject?: subject hint passed to the model

interface Props {
  count?: number;
  title?: string;
  subject?: string;
}
const { count = 5, title = 'Generate fresh practice', subject } = Astro.props;
const id = 'aiqg-' + Math.random().toString(36).slice(2, 9);
---

<section class="not-prose my-8 surface rounded-2xl shadow-soft" id={id} data-aiqg-root data-count={count} data-subject={subject ?? ''}>
  <header class="flex items-center justify-between gap-3 px-5 py-4 border-b border-ink-200 dark:border-ink-800">
    <div class="flex items-center gap-3">
      <span class="inline-flex items-center justify-center h-9 w-9 rounded-xl bg-gradient-to-br from-accent-700 to-ink-900 text-white font-serif font-semibold">
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/></svg>
      </span>
      <div>
        <h3 class="font-serif text-lg font-semibold leading-none">{title}</h3>
        <p class="text-xs text-ink-500 mt-1">AI generates {count} new MCQs based on this guide. 100% on-device.</p>
      </div>
    </div>
    <button
      type="button"
      data-aiqg-go
      class="inline-flex items-center gap-2 px-4 py-2 rounded-xl bg-accent-700 hover:bg-accent-800 dark:bg-accent-600 dark:hover:bg-accent-500 text-white text-sm font-medium transition-all shadow-soft hover:shadow-lift"
    >
      <span data-aiqg-go-label>Generate</span>
      <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
    </button>
  </header>

  <!-- Status / loading -->
  <div data-aiqg-status class="hidden px-5 py-4 text-sm border-b border-ink-100 dark:border-ink-800/60">
    <div class="flex items-center gap-2 text-ink-600 dark:text-ink-300">
      <svg class="h-4 w-4 animate-spin text-accent-700 dark:text-accent-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M21 12a9 9 0 1 1-6.219-8.56"/></svg>
      <span data-aiqg-status-label>Loading model...</span>
    </div>
    <div class="mt-2 h-1 rounded-full bg-ink-200 dark:bg-ink-800 overflow-hidden">
      <div class="h-full bg-accent-600 transition-all" style="width: 0%" data-aiqg-progress></div>
    </div>
  </div>

  <!-- Generated questions appear here -->
  <ol class="hidden p-5 space-y-6" data-aiqg-questions></ol>

  <div data-aiqg-error class="hidden px-5 py-4 text-sm text-rose-700 dark:text-rose-300"></div>
</section>

<script>
  import {
    MODELS,
    getDefaultModel,
    isWebGPUSupported,
    loadEngine,
    streamChat,
    getGuideContext,
    getPreferredModelId,
  } from '../lib/webllm';

  type Q = { q: string; choices: string[]; answer: number; explain?: string };

  const buildPrompt = (count: number, subject: string | null) => {
    const guide = getGuideContext(7000);
    return [
      `You are a quiz writer for a study tool. Generate ${count} multiple-choice questions based ONLY on the study guide below.`,
      subject ? `Subject: ${subject}.` : '',
      `Each question must have exactly 4 choices (one correct, three plausible distractors), the index of the correct answer (0-3), and a one-sentence explanation.`,
      `Output ONLY a JSON array, no preamble, no commentary, no markdown fences. Schema:`,
      `[{ "q": "...", "choices": ["A","B","C","D"], "answer": 0, "explain": "..." }, ...]`,
      ``,
      `--- GUIDE CONTENT ---`,
      guide || '(no guide content found)',
      `--- END GUIDE ---`,
    ].filter(Boolean).join('\n');
  };

  const extractJsonArray = (text: string): Q[] | null => {
    // Find the first [ and the matching last ].
    const start = text.indexOf('[');
    const end = text.lastIndexOf(']');
    if (start < 0 || end <= start) return null;
    const slice = text.slice(start, end + 1);
    try {
      const parsed = JSON.parse(slice);
      if (!Array.isArray(parsed)) return null;
      return parsed.filter((q: any): q is Q =>
        q && typeof q.q === 'string' &&
        Array.isArray(q.choices) && q.choices.length === 4 &&
        Number.isInteger(q.answer) && q.answer >= 0 && q.answer < 4
      );
    } catch {
      return null;
    }
  };

  const renderQuestions = (root: HTMLElement, qs: Q[]) => {
    const ol = root.querySelector('[data-aiqg-questions]') as HTMLElement;
    ol.innerHTML = '';
    qs.forEach((q, i) => {
      const li = document.createElement('li');
      li.dataset.answer = String(q.answer);
      li.innerHTML = `
        <div class="flex items-start gap-3 mb-3">
          <span class="text-xs font-mono text-ink-400 mt-1">${String(i + 1).padStart(2, '0')}</span>
          <p class="font-medium text-ink-900 dark:text-ink-100 text-pretty">${escapeHtml(q.q)}</p>
        </div>
        <div class="space-y-2 ml-7">
          ${q.choices.map((c, ci) => `
            <button type="button" data-choice="${ci}"
              class="aiqg-choice w-full text-left flex items-start gap-3 px-4 py-3 rounded-lg border border-ink-200 dark:border-ink-800 hover:border-accent-400 dark:hover:border-accent-600 transition-colors text-sm">
              <span class="aiqg-marker mt-0.5 inline-flex items-center justify-center h-5 w-5 rounded-full border border-ink-300 dark:border-ink-700 text-[10px] font-mono">${String.fromCharCode(65 + ci)}</span>
              <span class="flex-1">${escapeHtml(c)}</span>
            </button>
          `).join('')}
        </div>
        ${q.explain ? `
          <div class="aiqg-explain hidden ml-7 mt-3 px-4 py-3 rounded-lg bg-ink-50 dark:bg-ink-900/60 border border-ink-200 dark:border-ink-800 text-sm text-ink-700 dark:text-ink-300">
            <span class="font-semibold text-accent-700 dark:text-accent-300">Why: </span>${escapeHtml(q.explain)}
          </div>` : ''}
      `;
      ol.appendChild(li);

      // wire up choice clicks
      const correctIdx = q.answer;
      const choices = li.querySelectorAll('.aiqg-choice');
      let answered = false;
      choices.forEach((btnNode, ci) => {
        const btn = btnNode as HTMLButtonElement;
        btn.addEventListener('click', () => {
          if (answered) return;
          answered = true;
          choices.forEach((bNode, bi) => {
            const b = bNode as HTMLButtonElement;
            const marker = b.querySelector('.aiqg-marker')!;
            b.disabled = true;
            if (bi === correctIdx) {
              b.classList.add('border-emerald-400', 'bg-emerald-50', 'dark:bg-emerald-900/30');
              marker.classList.add('bg-emerald-500', 'text-white', 'border-emerald-500');
            } else if (bi === ci) {
              b.classList.add('border-rose-400', 'bg-rose-50', 'dark:bg-rose-900/30');
              marker.classList.add('bg-rose-500', 'text-white', 'border-rose-500');
            } else {
              b.classList.add('opacity-50');
            }
          });
          li.querySelector('.aiqg-explain')?.classList.remove('hidden');
        });
      });
    });
    ol.classList.remove('hidden');
  };

  const escapeHtml = (s: string) => s.replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c] || c));

  const setupOne = (root: HTMLElement) => {
    if ((root as any).__aiqgWired) return;
    (root as any).__aiqgWired = true;

    const count = Number(root.dataset.count || '5');
    const subject = root.dataset.subject || null;
    const goBtn = root.querySelector('[data-aiqg-go]') as HTMLButtonElement;
    const goLabel = root.querySelector('[data-aiqg-go-label]')!;
    const statusEl = root.querySelector('[data-aiqg-status]') as HTMLElement;
    const statusLabel = root.querySelector('[data-aiqg-status-label]')!;
    const progressEl = root.querySelector('[data-aiqg-progress]') as HTMLElement;
    const errorEl = root.querySelector('[data-aiqg-error]') as HTMLElement;

    const showError = (msg: string) => {
      errorEl.textContent = msg;
      errorEl.classList.remove('hidden');
    };
    const hideError = () => errorEl.classList.add('hidden');

    goBtn.addEventListener('click', async () => {
      hideError();
      if (!isWebGPUSupported()) {
        showError('WebGPU is required. Try Chrome, Edge, Arc, or Brave on a desktop or laptop.');
        return;
      }
      goBtn.disabled = true;
      goLabel.textContent = 'Generating...';
      statusEl.classList.remove('hidden');
      statusLabel.textContent = 'Loading model...';
      progressEl.style.width = '2%';

      try {
        const modelId = getPreferredModelId() || getDefaultModel().id;
        const engine = await loadEngine(modelId, (text, pct) => {
          statusLabel.textContent = text.replace(/^Loading model from cache\[/, 'Loading [');
          progressEl.style.width = Math.max(2, Math.round(pct * 100)) + '%';
        });

        statusLabel.textContent = 'Writing questions...';
        progressEl.style.width = '100%';

        const messages = [
          { role: 'system' as const, content: 'You are a precise quiz writer. Output only valid JSON.' },
          { role: 'user' as const, content: buildPrompt(count, subject) },
        ];

        let final = '';
        for await (const { full } of streamChat(engine, messages, { temperature: 0.7, maxTokens: 1800 })) {
          final = full;
          // Live status: count how many JSON objects look complete so far.
          const opens = (final.match(/\{/g) || []).length;
          statusLabel.textContent = `Writing questions... (${Math.min(opens, count)}/${count})`;
        }

        const parsed = extractJsonArray(final);
        if (!parsed || parsed.length === 0) {
          showError('The model returned malformed JSON. Click Generate to retry.');
          console.warn('[AIQuizGen] raw output:', final);
        } else {
          renderQuestions(root, parsed.slice(0, count));
        }
      } catch (err: any) {
        showError(err?.message || String(err));
        console.error('[AIQuizGen] failed', err);
      } finally {
        statusEl.classList.add('hidden');
        goBtn.disabled = false;
        goLabel.textContent = 'Regenerate';
      }
    });
  };

  const setup = () => {
    document.querySelectorAll('[data-aiqg-root]').forEach((el) => setupOne(el as HTMLElement));
  };
  setup();
  document.addEventListener('astro:after-swap', setup);
</script>
