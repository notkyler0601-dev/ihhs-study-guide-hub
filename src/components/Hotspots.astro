---
// Click-to-identify diagram. Each hotspot is positioned by percent (x,y) over the image.
interface Spot { x: number; y: number; label: string; description?: string; }
interface Props {
  image: string;
  alt?: string;
  spots: Spot[];
  title?: string;
  mode?: 'reveal' | 'quiz';
}
const { image, alt = '', spots, title, mode = 'reveal' } = Astro.props;
const id = 'hot-' + Math.random().toString(36).slice(2, 9);
const conf = JSON.stringify({ spots, mode });
---

<figure class="not-prose my-8 surface rounded-2xl shadow-soft overflow-hidden" id={id} data-hot data-conf={conf}>
  {title && (
    <figcaption class="px-5 py-3 border-b border-ink-200 dark:border-ink-800 flex items-center justify-between gap-3">
      <span class="font-serif text-base font-semibold">{title}</span>
      <span class="text-xs text-ink-500" data-hot-mode>{mode === 'quiz' ? 'Quiz mode' : 'Reveal mode'}</span>
    </figcaption>
  )}
  <div class="relative bg-ink-100 dark:bg-ink-800">
    <img src={image} alt={alt} class="block w-full h-auto" />
    <div data-hot-overlay class="absolute inset-0"></div>
  </div>
  <div data-hot-info class="px-5 py-3 border-t border-ink-200 dark:border-ink-800 text-sm min-h-[40px] text-ink-600 dark:text-ink-300"></div>
</figure>

<script is:inline>
  const init = () => {
    document.querySelectorAll('[data-hot]:not([data-hot-ready])').forEach((root) => {
      root.dataset.hotReady = '1';
      const conf = JSON.parse(root.dataset.conf || '{}');
      const overlay = root.querySelector('[data-hot-overlay]');
      const info = root.querySelector('[data-hot-info]');
      const spots = conf.spots || [];
      const isQuiz = conf.mode === 'quiz';

      let target = isQuiz ? Math.floor(Math.random() * spots.length) : -1;
      const announce = () => {
        if (!isQuiz) { info.textContent = 'Click any hotspot.'; return; }
        info.innerHTML = `Find: <strong>${spots[target].label}</strong>`;
      };

      spots.forEach((s, i) => {
        const dot = document.createElement('button');
        dot.type = 'button';
        dot.style.cssText = `position:absolute; left:${s.x}%; top:${s.y}%; transform:translate(-50%,-50%); width:24px; height:24px; border-radius:50%; background:rgba(185,28,28,0.85); border:2px solid #fff; box-shadow:0 0 0 2px rgba(0,0,0,0.2); cursor:pointer;`;
        dot.title = isQuiz ? '' : s.label;
        dot.setAttribute('data-i', i);
        dot.addEventListener('click', () => {
          if (!isQuiz) {
            info.innerHTML = `<strong>${s.label}</strong>${s.description ? ' &middot; ' + s.description : ''}`;
          } else {
            if (i === target) {
              info.innerHTML = `<span class="text-emerald-700 dark:text-emerald-400 font-medium">Correct: ${s.label}</span>`;
              dot.style.background = 'rgba(22,163,74,0.85)';
              setTimeout(() => { target = Math.floor(Math.random() * spots.length); announce(); }, 1200);
            } else {
              info.innerHTML = `<span class="text-rose-700 dark:text-rose-400 font-medium">Not quite. Try again.</span>`;
            }
          }
        });
        overlay.appendChild(dot);
      });

      announce();
    });
  };
  init();
  document.addEventListener('astro:after-swap', init);
</script>
