---
// <AIExplain>
//
// Wrap a paragraph or concept and add an "explain simpler" button.
// Click it → the WebLLM model generates a plain-English restatement,
// optionally at a specific reading level (ELI5, ELI15, technical).
//
// Usage in MDX:
//   <AIExplain>
//   RuBisCO's inefficiency arises from its dual affinity for O2 and CO2,
//   which can trigger photorespiration under high-O2 conditions.
//   </AIExplain>
//
//   <AIExplain level="eli5" topic="Newton's second law">
//   F = ma: the force on an object equals its mass times its acceleration.
//   </AIExplain>
//
// Props:
//   - level?: 'eli5' | 'eli15' | 'advanced' (default eli15)
//   - topic?: optional short label shown on the button

interface Props {
  level?: 'eli5' | 'eli15' | 'advanced' | 'caveman';
  topic?: string;
}
const { level = 'eli15', topic } = Astro.props;
const id = 'aix-' + Math.random().toString(36).slice(2, 9);

const LEVEL_LABELS: Record<string, string> = {
  eli5: 'Explain like I\'m 5',
  eli15: 'Explain simpler',
  advanced: 'Go deeper',
  caveman: 'In caveman terms',
};
const btnLabel = LEVEL_LABELS[level] ?? 'Explain simpler';
---

<div class="not-prose my-4 rounded-xl border border-ink-200 dark:border-ink-800 bg-white dark:bg-ink-900 overflow-hidden" id={id} data-aix-root data-level={level} data-topic={topic ?? ''}>
  <div class="p-5">
    <div data-aix-original class="text-sm text-ink-800 dark:text-ink-200 leading-relaxed">
      <slot />
    </div>

    <div data-aix-output class="hidden mt-4 pt-4 border-t border-dashed border-accent-300 dark:border-accent-800">
      <div class="flex items-center gap-2 mb-2 text-[11px] uppercase tracking-[0.14em] font-semibold text-accent-700 dark:text-accent-400">
        <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M13 2 3 14h9l-1 8 10-12h-9l1-8z"/></svg>
        <span data-aix-output-label>AI restated</span>
      </div>
      <div data-aix-body class="text-sm text-ink-800 dark:text-ink-200 leading-relaxed"></div>
    </div>
  </div>

  <div class="flex items-center justify-between gap-3 px-5 py-2.5 border-t border-ink-100 dark:border-ink-800/60 bg-ink-50/60 dark:bg-ink-900/60">
    <div class="flex items-center gap-1.5">
      <select data-aix-level class="text-[11px] bg-transparent border-0 text-ink-500 focus:outline-none focus:text-accent-700 cursor-pointer pr-1">
        <option value="eli5" selected={level === 'eli5'}>Like I'm 5</option>
        <option value="eli15" selected={level === 'eli15'}>Simpler (default)</option>
        <option value="advanced" selected={level === 'advanced'}>Go deeper</option>
        <option value="caveman" selected={level === 'caveman'}>🪨 Caveman</option>
      </select>
    </div>
    <button
      type="button"
      data-aix-go
      class="inline-flex items-center gap-1.5 px-3 py-1 rounded-md text-xs font-medium text-accent-700 dark:text-accent-400 hover:bg-accent-50 dark:hover:bg-accent-900/30 transition-colors"
    >
      <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4"/></svg>
      <span data-aix-go-label>{btnLabel}</span>
    </button>
  </div>
</div>

<script>
  import { marked } from 'marked';
  import DOMPurify from 'dompurify';
  import {
    isWebGPUSupported,
    loadEngine,
    streamChat,
    getPreferredModelId,
    getDefaultModel,
  } from '../lib/webllm';

  marked.setOptions({ breaks: true, gfm: true });
  const renderMd = (md: string) => DOMPurify.sanitize(marked.parse(md, { async: false }) as string);

  const LEVEL_BRIEFS: Record<string, string> = {
    eli5: 'Use simple words a 10-year-old would understand. Use a concrete, vivid analogy. One short paragraph, 3-4 sentences max.',
    eli15: 'Use plain language, no jargon. Short paragraph. Define any technical term inline the first time you use it. Give one concrete example.',
    advanced: 'Go deeper. Add nuance, edge cases, and related ideas a motivated student would find interesting. Use precise terminology and brief examples.',
    caveman: 'You are a CAVEMAN explaining this. Use ONLY tiny primitive words. Short caveman sentences. Drop pronouns and articles where natural ("Rock heavy. Push rock. Rock fall."). Use stone-age analogies (rocks, fire, sky, hunt, tribe, mammoth, sun). MUST stay technically accurate, just sound primitive. Be punchy and memorable. End with one short caveman moral or lesson. Maximum 5 sentences. UGH.',
  };

  const setupOne = (root: HTMLElement) => {
    if ((root as any).__aixWired) return;
    (root as any).__aixWired = true;

    const topic = root.dataset.topic || null;
    const originalEl = root.querySelector('[data-aix-original]') as HTMLElement;
    const outputEl = root.querySelector('[data-aix-output]') as HTMLElement;
    const outputLabel = root.querySelector('[data-aix-output-label]')!;
    const bodyEl = root.querySelector('[data-aix-body]') as HTMLElement;
    const goBtn = root.querySelector('[data-aix-go]') as HTMLButtonElement;
    const goLabel = root.querySelector('[data-aix-go-label]')!;
    const levelSelect = root.querySelector('[data-aix-level]') as HTMLSelectElement;

    goBtn.addEventListener('click', async () => {
      if (!isWebGPUSupported()) {
        outputEl.classList.remove('hidden');
        outputLabel.textContent = 'AI unavailable';
        bodyEl.innerHTML = '<p class="text-rose-600 dark:text-rose-400">WebGPU is required. Try Chrome, Edge, Arc, or Brave on a desktop.</p>';
        return;
      }
      const level = levelSelect.value;
      const original = (originalEl.textContent ?? '').trim();
      if (!original) return;

      goBtn.disabled = true;
      goLabel.textContent = 'Loading...';
      outputEl.classList.remove('hidden');
      outputLabel.textContent = level === 'eli5' ? 'Explain like I\'m 5'
        : level === 'advanced' ? 'Going deeper'
        : level === 'caveman' ? '🪨 Caveman talk'
        : 'Simpler explanation';
      bodyEl.innerHTML = '<span class="opacity-50">Thinking...</span>';

      try {
        const modelId = getPreferredModelId() || getDefaultModel().id;
        const engine = await loadEngine(modelId, (text, pct) => {
          if (pct < 1) goLabel.textContent = `Loading ${Math.round(pct * 100)}%`;
        });
        goLabel.textContent = 'Writing...';

        const systemPrompt = [
          `You are a patient study tutor.`,
          `The student is reading the passage below and wants a clearer restatement.`,
          LEVEL_BRIEFS[level] ?? LEVEL_BRIEFS.eli15,
          topic ? `Topic context: ${topic}.` : '',
          `Return only the restatement. No preamble like "Sure, here is...".`,
        ].filter(Boolean).join(' ');

        const messages = [
          { role: 'system' as const, content: systemPrompt },
          { role: 'user' as const, content: `Passage:\n"""\n${original}\n"""` },
        ];

        let final = '';
        for await (const { full } of streamChat(engine, messages, { temperature: 0.5, maxTokens: 500 })) {
          final = full;
          bodyEl.innerHTML = renderMd(final);
        }
      } catch (err: any) {
        bodyEl.innerHTML = `<p class="text-rose-600 dark:text-rose-400">Failed: ${err?.message || err}</p>`;
      } finally {
        goBtn.disabled = false;
        goLabel.textContent = 'Regenerate';
      }
    });
  };

  const setup = () => {
    document.querySelectorAll('[data-aix-root]').forEach((el) => setupOne(el as HTMLElement));
  };
  setup();
  document.addEventListener('astro:after-swap', setup);
</script>
