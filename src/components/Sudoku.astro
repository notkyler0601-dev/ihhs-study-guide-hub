---
// Interactive sudoku puzzle. Generates puzzles at various difficulty levels
// and validates solutions. Uses the sudoku.js library.
interface Props {
  title?: string;
  difficulty?: 'easy' | 'medium' | 'hard' | 'very-hard' | 'insane' | 'inhuman';
  givens?: string;  // 81-char puzzle string, '.' for empty; overrides difficulty
}
const { title = 'Sudoku', difficulty = 'medium', givens } = Astro.props;
const id = 'sud-' + Math.random().toString(36).slice(2, 9);
const conf = JSON.stringify({ difficulty, givens });
---

<section class="not-prose my-8 surface rounded-2xl p-5 shadow-soft" id={id} data-sud data-conf={conf}>
  <header class="mb-4 flex items-center justify-between gap-3 flex-wrap">
    <span class="font-serif text-base font-semibold">{title}</span>
    <div class="flex items-center gap-2 text-xs">
      <button data-sud-check type="button" class="px-3 py-1 rounded-md bg-accent-700 hover:bg-accent-800 text-white dark:bg-accent-600 dark:hover:bg-accent-500 font-medium">Check</button>
      <button data-sud-solve type="button" class="px-3 py-1 rounded-md bg-ink-100 dark:bg-ink-800 hover:bg-ink-200 dark:hover:bg-ink-700">Solve</button>
      <button data-sud-new   type="button" class="px-3 py-1 rounded-md bg-ink-100 dark:bg-ink-800 hover:bg-ink-200 dark:hover:bg-ink-700">New</button>
    </div>
  </header>
  <div data-sud-grid class="mx-auto grid grid-cols-9 gap-0 w-max select-none"></div>
  <div data-sud-msg class="mt-3 text-center text-sm min-h-[1.25rem]"></div>
</section>

<style>
  [data-sud-grid] input {
    width: 40px; height: 40px;
    text-align: center;
    font-family: 'JetBrains Mono', monospace;
    font-size: 1.1rem;
    border: 1px solid theme('colors.ink.300');
    background: theme('colors.white');
    color: theme('colors.ink.900');
  }
  .dark [data-sud-grid] input {
    border-color: theme('colors.ink.700');
    background: theme('colors.ink.900');
    color: theme('colors.ink.50');
  }
  [data-sud-grid] input:focus {
    outline: none;
    background: theme('colors.accent.50');
  }
  .dark [data-sud-grid] input:focus {
    background: theme('colors.accent.900' / 40%);
  }
  [data-sud-grid] input[data-given="1"] {
    font-weight: 700;
    background: theme('colors.ink.50');
  }
  .dark [data-sud-grid] input[data-given="1"] {
    background: theme('colors.ink.800');
  }
  [data-sud-grid] input.sud-right { color: theme('colors.emerald.600'); }
  [data-sud-grid] input.sud-wrong { color: theme('colors.rose.600'); }
  /* Thicker borders between 3x3 regions */
  @media (min-width: 0) {
    [data-sud-grid] input:nth-child(3n) { border-right-width: 2px; }
    [data-sud-grid] input:nth-child(9n+1) { border-left-width: 2px; }
    [data-sud-grid] input:nth-child(n+1):nth-child(-n+9),
    [data-sud-grid] input:nth-child(n+28):nth-child(-n+36),
    [data-sud-grid] input:nth-child(n+55):nth-child(-n+63) { border-top-width: 2px; }
    [data-sud-grid] input:nth-child(n+19):nth-child(-n+27),
    [data-sud-grid] input:nth-child(n+46):nth-child(-n+54),
    [data-sud-grid] input:nth-child(n+73):nth-child(-n+81) { border-bottom-width: 2px; }
  }
</style>

<script>
  import { loadScript, waitForGlobal } from '../lib/loadScript';

  const init = async () => {
    const roots = document.querySelectorAll<HTMLElement>('[data-sud]:not([data-sud-ready])');
    if (roots.length === 0) return;

    await loadScript('https://cdn.jsdelivr.net/npm/sudoku@0.1.3/sudoku.min.js');
    const sudoku: any = await waitForGlobal('sudoku');

    roots.forEach((root) => {
      root.dataset.sudReady = '1';
      const gridHost = root.querySelector<HTMLElement>('[data-sud-grid]')!;
      const msg = root.querySelector<HTMLElement>('[data-sud-msg]')!;
      const conf = JSON.parse(root.dataset.conf || '{}');

      let givens: string = (conf.givens && conf.givens.length === 81)
        ? conf.givens.replace(/[^1-9.]/g, '.')
        : sudoku.generate(conf.difficulty ?? 'medium');

      const render = () => {
        gridHost.innerHTML = '';
        for (let i = 0; i < 81; i++) {
          const inp = document.createElement('input');
          inp.type = 'text';
          inp.maxLength = 1;
          inp.inputMode = 'numeric';
          inp.dataset.i = String(i);
          const v = givens[i];
          if (v !== '.') { inp.value = v; inp.readOnly = true; inp.dataset.given = '1'; }
          inp.addEventListener('input', () => {
            inp.value = inp.value.replace(/[^1-9]/g, '').slice(0, 1);
            inp.classList.remove('sud-right', 'sud-wrong');
          });
          gridHost.appendChild(inp);
        }
        msg.textContent = '';
      };

      const readBoard = (): string => {
        const inputs = gridHost.querySelectorAll<HTMLInputElement>('input');
        let s = '';
        inputs.forEach((el) => { s += el.value ? el.value : '.'; });
        return s;
      };

      const check = () => {
        const solution = sudoku.solve(givens);
        if (!solution) { msg.textContent = 'No solution for this puzzle.'; return; }
        const current = readBoard();
        let correct = 0, filled = 0;
        gridHost.querySelectorAll<HTMLInputElement>('input').forEach((el, i) => {
          if (el.readOnly) return;
          el.classList.remove('sud-right', 'sud-wrong');
          if (!el.value) return;
          filled++;
          if (el.value === solution[i]) { el.classList.add('sud-right'); correct++; }
          else el.classList.add('sud-wrong');
        });
        const total = 81 - givens.split('').filter((c) => c !== '.').length;
        msg.textContent = filled === total && correct === total
          ? 'Solved.'
          : `${correct} correct, ${filled - correct} wrong, ${total - filled} blank.`;
      };

      const solve = () => {
        const solution = sudoku.solve(givens);
        if (!solution) { msg.textContent = 'No solution.'; return; }
        gridHost.querySelectorAll<HTMLInputElement>('input').forEach((el, i) => {
          if (el.readOnly) return;
          el.value = solution[i];
          el.classList.remove('sud-wrong'); el.classList.add('sud-right');
        });
        msg.textContent = 'Solved.';
      };

      const newPuzzle = () => {
        givens = sudoku.generate(conf.difficulty ?? 'medium');
        render();
      };

      root.querySelector('[data-sud-check]')?.addEventListener('click', check);
      root.querySelector('[data-sud-solve]')?.addEventListener('click', solve);
      root.querySelector('[data-sud-new]')?.addEventListener('click', newPuzzle);
      render();
    });
  };
  init();
  document.addEventListener('astro:after-swap', init);
</script>
