---
interface Heading { depth: number; slug: string; text: string; }
interface Props { headings: Heading[]; }
const { headings } = Astro.props;
const items = headings.filter((h) => h.depth >= 2 && h.depth <= 3);
---

<nav id="toc" aria-label="Table of contents" class="text-sm">
  <div class="mb-3 text-[11px] uppercase tracking-[0.16em] font-semibold text-ink-500 dark:text-ink-400">
    On this page
  </div>
  <ul class="space-y-1 border-l border-ink-200 dark:border-ink-800">
    {items.map((h) => (
      <li>
        <a
          href={`#${h.slug}`}
          data-toc-link={h.slug}
          class:list={[
            'block py-1 pl-4 -ml-px border-l border-transparent transition-colors',
            'text-ink-600 dark:text-ink-400 hover:text-accent-700 dark:hover:text-accent-300',
            h.depth === 3 && 'pl-7 text-xs',
          ]}
        >
          {h.text}
        </a>
      </li>
    ))}
  </ul>
</nav>

<script is:inline>
  const setup = () => {
    const links = document.querySelectorAll('[data-toc-link]');
    if (links.length === 0) return;
    const map = new Map();
    links.forEach((l) => map.set(l.getAttribute('data-toc-link'), l));

    const setActive = (slug) => {
      links.forEach((l) => {
        const active = l.getAttribute('data-toc-link') === slug;
        l.classList.toggle('text-accent-700', active);
        l.classList.toggle('dark:text-accent-300', active);
        l.classList.toggle('border-accent-500', active);
        l.classList.toggle('font-medium', active);
      });
    };

    const observer = new IntersectionObserver((entries) => {
      const visible = entries.filter((e) => e.isIntersecting)
        .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);
      if (visible[0]) setActive(visible[0].target.id);
    }, { rootMargin: '-80px 0px -70% 0px', threshold: 0 });

    document.querySelectorAll('h2[id], h3[id]').forEach((h) => observer.observe(h));
  };
  setup();
  document.addEventListener('astro:after-swap', setup);
</script>
