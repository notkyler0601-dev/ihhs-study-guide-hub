---
// Embed a Falstad CircuitJS simulator. Pass a circuit string (export from circuitjs)
// or a starter kit: "rc", "rl", "diode", "rectifier", "transistor", or leave empty for a blank board.
interface Props {
  title?: string;
  circuit?: string;
  starter?: string;
  height?: number;
}
const { title = 'Circuit simulator', circuit, starter, height = 540 } = Astro.props;

let url = 'https://www.falstad.com/circuit/circuitjs.html?running=true&hideMenu=false';
if (starter) url += `&startCircuit=${encodeURIComponent(starter + '.txt')}`;
if (circuit) url += `&ctz=${encodeURIComponent(circuit)}`;
---

<figure class="not-prose my-8 surface rounded-2xl overflow-hidden shadow-soft">
  <figcaption class="px-5 py-3 border-b border-ink-200 dark:border-ink-800 flex items-center justify-between gap-3">
    <span class="font-serif text-base font-semibold">{title}</span>
    <span class="text-[10px] uppercase tracking-[0.16em] text-ink-500 font-semibold">CircuitJS</span>
  </figcaption>
  <div class="relative w-full bg-ink-100 dark:bg-ink-800" style={`height:${height}px`}>
    <iframe
      src={url}
      title={title}
      class="absolute inset-0 w-full h-full"
      loading="lazy"
      allowfullscreen
    ></iframe>
  </div>
</figure>
