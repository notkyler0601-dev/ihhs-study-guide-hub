---
// Visual math equation editor powered by MathLive (loaded from CDN on demand).
// Type math like a calculator, get a beautifully rendered equation.
//
// Usage:
//   <EquationEditor initial="\\frac{a}{b} + c" />

interface Props {
  initial?: string;        // LaTeX
  placeholder?: string;
  prompt?: string;
  height?: string;
}

const {
  initial = '',
  placeholder = 'Type math here. Try \\frac, \\sqrt, ^, _, \\pi',
  prompt = 'Live equation editor. Use the keyboard or the on-screen buttons.',
  height = 'auto',
} = Astro.props;

const id = 'eq-' + Math.random().toString(36).slice(2, 9);
---

<figure class="not-prose my-8">
  <div class="surface rounded-2xl shadow-soft p-5">
    <div class="flex items-center gap-2 mb-3 text-xs uppercase tracking-[0.14em] text-ink-500 font-semibold">
      <span class="inline-flex items-center justify-center h-6 w-6 rounded bg-accent-700 dark:bg-accent-600 text-white font-serif">∑</span>
      Equation editor
    </div>
    <math-field
      id={id}
      placeholder={placeholder}
      class="block w-full text-2xl px-4 py-3 rounded-lg border border-ink-200 dark:border-ink-800 bg-white dark:bg-ink-900 text-ink-900 dark:text-ink-50"
      style={`min-height: 60px; ${height === 'auto' ? '' : `height: ${height};`}`}
    >{initial}</math-field>
    <div class="mt-3 flex items-center gap-2 text-xs">
      <button data-eq-copy={id} class="px-2 py-1 rounded text-ink-500 hover:text-accent-700 dark:hover:text-accent-400">Copy LaTeX</button>
      <span class="text-ink-400 truncate" data-eq-latex></span>
    </div>
  </div>
  <p class="text-[11px] text-ink-500 text-center mt-2 italic">{prompt}</p>
</figure>

<script type="module" define:vars={{ id }}>
  const ensureMathLive = () =>
    new Promise((resolve, reject) => {
      if (window.MathfieldElement) return resolve();
      const s = document.createElement('script');
      s.type = 'module';
      s.src = 'https://unpkg.com/mathlive@0.101.0/dist/mathlive.min.mjs';
      s.onload = () => resolve();
      s.onerror = () => reject(new Error('Failed to load MathLive'));
      document.head.appendChild(s);
    });

  const setup = async () => {
    const el = document.getElementById(id);
    if (!el || el.dataset.initialized === 'true') return;
    el.dataset.initialized = 'true';
    try {
      await ensureMathLive();
      const latexLabel = el.parentElement?.querySelector('[data-eq-latex]');
      const copyBtn = el.parentElement?.querySelector(`[data-eq-copy="${id}"]`);
      const sync = () => {
        if (latexLabel) latexLabel.textContent = el.value;
      };
      el.addEventListener('input', sync);
      sync();
      copyBtn?.addEventListener('click', async () => {
        await navigator.clipboard.writeText(el.value);
        copyBtn.textContent = 'Copied!';
        setTimeout(() => { copyBtn.textContent = 'Copy LaTeX'; }, 1200);
      });
    } catch (e) {
      console.warn('Equation editor failed', e);
    }
  };
  setup();
  document.addEventListener('astro:after-swap', setup);
</script>
