---
interface Props {
  type?: 'note' | 'insight' | 'warning' | 'tip' | 'theorem' | 'definition';
  title?: string;
}
const { type = 'note', title } = Astro.props;

const config = {
  note:       { label: 'Note',       border: 'border-ink-300 dark:border-ink-700',     bg: 'bg-ink-50 dark:bg-ink-900/40',                     icon: '✎', accent: 'text-ink-700 dark:text-ink-300' },
  insight:    { label: 'Insight',    border: 'border-accent-300 dark:border-accent-700', bg: 'bg-accent-50 dark:bg-accent-900/30',             icon: '✦', accent: 'text-accent-700 dark:text-accent-300' },
  warning:    { label: 'Watch out',  border: 'border-amber-300 dark:border-amber-700', bg: 'bg-amber-50 dark:bg-amber-900/30',                 icon: '⚠', accent: 'text-amber-800 dark:text-amber-300' },
  tip:        { label: 'Tip',        border: 'border-emerald-300 dark:border-emerald-700', bg: 'bg-emerald-50 dark:bg-emerald-900/30',         icon: '➤', accent: 'text-emerald-800 dark:text-emerald-300' },
  theorem:    { label: 'Theorem',    border: 'border-ink-400 dark:border-ink-600',     bg: 'bg-ink-100 dark:bg-ink-800/60',                    icon: '∎', accent: 'text-ink-800 dark:text-ink-200' },
  definition: { label: 'Definition', border: 'border-accent-200 dark:border-accent-800', bg: 'bg-accent-50/60 dark:bg-accent-900/20',          icon: '≝', accent: 'text-accent-800 dark:text-accent-300' },
}[type];
---

<aside class:list={['not-prose my-6 rounded-xl border-l-4 p-5 shadow-soft', config.border, config.bg]}>
  <div class:list={['flex items-center gap-2 mb-2 text-xs uppercase tracking-[0.14em] font-semibold', config.accent]}>
    <span class="text-base leading-none">{config.icon}</span>
    <span>{title ?? config.label}</span>
  </div>
  <div class="text-[0.95rem] leading-relaxed text-ink-800 dark:text-ink-200">
    <slot />
  </div>
</aside>
