---
// Dorling cartogram: each region is replaced by a circle sized by its data value.
// Simpler and more reliable than continuous cartograms. Defaults to US states.
interface Props {
  title?: string;
  data: Record<string, number>;
  geoUrl?: string;
  objectName?: string;
  height?: number;
}
const {
  title = 'Cartogram',
  data,
  geoUrl = 'https://cdn.jsdelivr.net/npm/us-atlas@3.0.1/states-10m.json',
  objectName = 'states',
  height = 480,
} = Astro.props;
const id = 'cg-' + Math.random().toString(36).slice(2, 9);
const conf = JSON.stringify({ data, geoUrl, objectName });
---

<figure class="not-prose my-8 surface rounded-2xl shadow-soft p-5" id={id} data-cg data-conf={conf}>
  <figcaption class="mb-3 font-serif text-base font-semibold">{title}</figcaption>
  <div data-cg-host class="w-full" style={`min-height:${height}px`}></div>
</figure>

<script>
  const init = async () => {
    const roots = document.querySelectorAll<HTMLElement>('[data-cg]:not([data-cg-ready])');
    if (roots.length === 0) return;
    let d3: any, topojson: any;
    try {
      d3 = await import(/* @vite-ignore */ 'https://cdn.jsdelivr.net/npm/d3@7/+esm');
      topojson = await import(/* @vite-ignore */ 'https://cdn.jsdelivr.net/npm/topojson-client@3.1.0/+esm');
    } catch (e) { console.warn('Cartogram deps failed', e); return; }

    for (const root of roots) {
      root.dataset.cgReady = '1';
      const host = root.querySelector<HTMLElement>('[data-cg-host]')!;
      const conf = JSON.parse(root.dataset.conf || '{}');
      try {
        const topo = await fetch(conf.geoUrl).then((r) => r.json());
        const features = topojson.feature(topo, topo.objects[conf.objectName]).features;
        const w = host.clientWidth || 720;
        const h = 480;
        const path = d3.geoPath(d3.geoIdentity().reflectY(true).fitSize([w, h], { type: 'FeatureCollection', features }));

        const max = Math.max(...Object.values(conf.data) as number[], 1);
        const r = d3.scaleSqrt().domain([0, max]).range([0, 38]);

        // Initial positions: region centroids
        const nodes = features.map((f: any) => {
          const [x, y] = path.centroid(f);
          const value = conf.data[String(f.id)] ?? 0;
          return { id: f.id, name: f.properties?.name ?? f.id, x, y, r: r(value), value };
        });

        // Run a few force-simulation ticks to push circles apart
        const sim = d3.forceSimulation(nodes)
          .force('x', d3.forceX((d: any) => d.x).strength(0.4))
          .force('y', d3.forceY((d: any) => d.y).strength(0.4))
          .force('collide', d3.forceCollide((d: any) => d.r + 1).strength(0.9))
          .stop();
        for (let i = 0; i < 200; i++) sim.tick();

        const svg = d3.select(host).append('svg').attr('viewBox', `0 0 ${w} ${h}`).attr('width', w).attr('height', h);
        svg.append('g').selectAll('circle').data(nodes).join('circle')
          .attr('cx', (d: any) => d.x).attr('cy', (d: any) => d.y).attr('r', (d: any) => d.r)
          .attr('fill', '#b91c1c').attr('fill-opacity', 0.85).attr('stroke', '#fff').attr('stroke-width', 1)
          .append('title').text((d: any) => `${d.name}: ${d.value}`);
      } catch (e) {
        console.warn('Cartogram failed', e);
      }
    }
  };
  init();
  document.addEventListener('astro:after-swap', init);
</script>
