---
// <FloatingAITutor>
//
// Floating action button (bottom-right) that opens a slide-in drawer
// containing the full AITutor chat. Mounted globally in GuideLayout so it's
// available on every guide without authors having to add anything.
//
// State persists in memory across the drawer being closed/reopened (the
// AITutor inside keeps its message history because we only hide the panel,
// never destroy it). Closes on Esc, click outside, or the X button.
//
// Hides itself on the /signup, /login, /admin pages where it doesn't apply.

import AITutor from './AITutor.astro';
---

<!-- Floating action button -->
<button
  type="button"
  id="fab-tutor"
  class="no-print fixed bottom-6 right-6 z-30 group inline-flex items-center gap-2 h-14 pl-4 pr-5 rounded-full bg-gradient-to-br from-accent-700 to-accent-900 dark:from-accent-600 dark:to-accent-800 text-white shadow-lift hover:shadow-glow hover:-translate-y-0.5 transition-all"
  aria-label="Open AI tutor"
  title="Ask the AI tutor (⌘ /)"
>
  <span class="relative inline-flex items-center justify-center h-10 w-10 rounded-full bg-white/15">
    <span class="absolute inset-0 rounded-full bg-white/0 group-hover:bg-white/10 transition-colors"></span>
    <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/>
    </svg>
    <span class="absolute -top-0.5 -right-0.5 inline-flex h-2.5 w-2.5">
      <span class="absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75 animate-ping"></span>
      <span class="relative inline-flex h-2.5 w-2.5 rounded-full bg-emerald-500 ring-2 ring-accent-700 dark:ring-accent-600"></span>
    </span>
  </span>
  <span class="hidden sm:inline text-sm font-medium">Ask AI</span>
</button>

<!-- Backdrop -->
<div
  id="fab-tutor-backdrop"
  class="no-print fixed inset-0 z-40 bg-ink-950/40 backdrop-blur-sm opacity-0 pointer-events-none transition-opacity duration-200"
  aria-hidden="true"
></div>

<!-- Drawer -->
<aside
  id="fab-tutor-drawer"
  class="no-print fixed top-0 right-0 z-50 h-full w-full sm:w-[480px] surface !rounded-none sm:!rounded-l-2xl shadow-lift translate-x-full transition-transform duration-300 ease-out flex flex-col"
  role="dialog"
  aria-modal="true"
  aria-label="AI study tutor"
>
  <header class="flex items-center justify-between gap-3 px-5 py-3 border-b border-ink-200 dark:border-ink-800 shrink-0">
    <div class="flex items-center gap-2 min-w-0">
      <span class="inline-flex items-center justify-center h-8 w-8 rounded-lg bg-gradient-to-br from-accent-700 to-ink-950 text-white text-sm">✦</span>
      <div class="min-w-0">
        <div class="font-serif text-sm font-semibold leading-none truncate">AI study tutor</div>
        <div class="text-[10px] text-ink-500 mt-0.5">Available on every guide</div>
      </div>
    </div>
    <div class="flex items-center gap-1 shrink-0">
      <span class="hidden sm:inline-flex items-center gap-1 text-[10px] text-ink-500 mr-2"><kbd class="kbd">⌘</kbd><kbd class="kbd">/</kbd></span>
      <button
        type="button"
        id="fab-tutor-close"
        class="inline-flex items-center justify-center h-8 w-8 rounded-lg hover:bg-ink-100 dark:hover:bg-ink-800 text-ink-500 hover:text-ink-900 dark:hover:text-ink-100 transition-colors"
        aria-label="Close AI tutor"
      >
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M18 6 6 18M6 6l12 12"/></svg>
      </button>
    </div>
  </header>

  <div class="flex-1 overflow-y-auto scrollbar-thin px-3 py-3">
    <AITutor title="Ask anything" heightClass="h-[calc(100vh-220px)]" />
  </div>
</aside>

<script is:inline>
  (() => {
    const setup = () => {
      const fab = document.getElementById('fab-tutor');
      const drawer = document.getElementById('fab-tutor-drawer');
      const backdrop = document.getElementById('fab-tutor-backdrop');
      const closeBtn = document.getElementById('fab-tutor-close');
      if (!fab || !drawer || !backdrop || !closeBtn) return;
      if (fab.dataset.wired === '1') return;
      fab.dataset.wired = '1';

      // Hide on auth/admin pages where it's not relevant
      const path = window.location.pathname;
      const skip = ['/signup', '/login', '/admin'];
      if (skip.some((p) => path.startsWith(p))) {
        fab.style.display = 'none';
        drawer.style.display = 'none';
        backdrop.style.display = 'none';
        return;
      }

      let isOpen = false;
      const open = () => {
        isOpen = true;
        drawer.classList.remove('translate-x-full');
        backdrop.classList.remove('opacity-0', 'pointer-events-none');
        backdrop.classList.add('opacity-100');
        fab.classList.add('opacity-0', 'pointer-events-none');
        // Try to focus the textarea inside
        setTimeout(() => {
          const ta = drawer.querySelector('[data-tutor-input]');
          if (ta && ta instanceof HTMLTextAreaElement) ta.focus();
        }, 320);
      };
      const close = () => {
        isOpen = false;
        drawer.classList.add('translate-x-full');
        backdrop.classList.add('opacity-0', 'pointer-events-none');
        backdrop.classList.remove('opacity-100');
        fab.classList.remove('opacity-0', 'pointer-events-none');
      };
      const toggle = () => (isOpen ? close() : open());

      fab.addEventListener('click', toggle);
      closeBtn.addEventListener('click', close);
      backdrop.addEventListener('click', close);

      // Keyboard: Esc closes; Cmd/Ctrl+/ toggles
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && isOpen) { e.preventDefault(); close(); return; }
        if ((e.metaKey || e.ctrlKey) && e.key === '/') { e.preventDefault(); toggle(); }
      });
    };
    setup();
    document.addEventListener('astro:after-swap', setup);
  })();
</script>
