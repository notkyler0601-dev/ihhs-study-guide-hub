---
// Hierarchical treemap. data: { name, value?, children?: [...] }
interface Node { name: string; value?: number; children?: Node[]; }
interface Props {
  title?: string;
  data: Node;
  height?: number;
}
const { title = 'Treemap', data, height = 460 } = Astro.props;
const id = 'tm-' + Math.random().toString(36).slice(2, 9);
const conf = JSON.stringify(data);
---

<figure class="not-prose my-8 surface rounded-2xl shadow-soft p-5" id={id} data-tm data-conf={conf}>
  <figcaption class="mb-3 font-serif text-base font-semibold">{title}</figcaption>
  <div data-tm-host class="w-full" style={`min-height:${height}px`}></div>
</figure>

<script>
  const init = async () => {
    const roots = document.querySelectorAll<HTMLElement>('[data-tm]:not([data-tm-ready])');
    if (roots.length === 0) return;

    let d3: any;
    try {
      d3 = await import(/* @vite-ignore */ 'https://cdn.jsdelivr.net/npm/d3@7/+esm');
    } catch (e) {
      console.warn('TreeMap d3 failed', e);
      return;
    }

    roots.forEach((root) => {
      root.dataset.tmReady = '1';
      const host = root.querySelector<HTMLElement>('[data-tm-host]')!;
      const data = JSON.parse(root.dataset.conf || '{}');
      const w = host.clientWidth || 720;
      const h = 460;
      const palette = ['#b91c1c', '#7f1d1d', '#dc2626', '#991b1b', '#27272a', '#52525b'];

      const root2 = d3.hierarchy(data).sum((d: any) => d.value || 0).sort((a: any, b: any) => b.value - a.value);
      d3.treemap().size([w, h]).padding(2)(root2);

      const svg = d3.select(host).append('svg').attr('width', w).attr('height', h);
      const cell = svg.selectAll('g').data(root2.leaves()).join('g').attr('transform', (d: any) => `translate(${d.x0},${d.y0})`);
      cell.append('rect')
        .attr('width', (d: any) => d.x1 - d.x0).attr('height', (d: any) => d.y1 - d.y0)
        .attr('fill', (_d: any, i: number) => palette[i % palette.length])
        .attr('rx', 3);
      cell.append('text')
        .attr('x', 6).attr('y', 16)
        .attr('font-size', 11).attr('font-family', 'Inter, sans-serif').attr('fill', '#fff').attr('font-weight', 600)
        .text((d: any) => d.data.name)
        .each(function(this: SVGTextElement, d: any) {
          const w2 = d.x1 - d.x0; const txt = this.textContent ?? '';
          if (w2 < (txt.length * 7)) this.textContent = txt.slice(0, Math.max(0, Math.floor(w2 / 7) - 1)) + '…';
        });
      cell.append('title').text((d: any) => `${d.data.name}: ${d.value}`);
    });
  };
  init();
  document.addEventListener('astro:after-swap', init);
</script>
