---
// Floating bottom-right AI tutor. Chat + quick actions (explain simpler,
// generate practice questions, summarize). Pulls the surrounding guide's
// prose as context so answers stay grounded in what the student is reading.
//
// While the tutor panel is open, hovering a paragraph / list item /
// blockquote / code block inside the guide shows a soft outline plus a
// floating action bar with "Simpler" and "Caveman" buttons that re-explain
// just that passage.
//
// Open to everyone, no account needed. Requires PUBLIC_AI_TUTOR_URL
// pointing at the Cloudflare Worker in worker/.
interface Props {
  guideTitle?: string;
}
const { guideTitle } = Astro.props;
const endpoint = import.meta.env.PUBLIC_AI_TUTOR_URL as string | undefined;
---

<div
  class="no-print tutor-widget"
  data-tutor-root
  data-tutor-endpoint={endpoint ?? ''}
  data-tutor-guide={guideTitle ?? ''}
>
  <button
    type="button"
    data-tutor-fab
    aria-label="Open AI tutor"
    class="tutor-fab"
  >
    <span class="tutor-fab-ring" aria-hidden="true"></span>
    <span class="tutor-fab-core">
      <svg class="h-[18px] w-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M12 2 9 9l-7 3 7 3 3 7 3-7 7-3-7-3z"/>
      </svg>
    </span>
    <span class="tutor-fab-label">
      <span class="tutor-fab-label-top">AI TUTOR</span>
      <span class="tutor-fab-label-bot">ready</span>
    </span>
  </button>

  <div
    data-tutor-panel
    class="tutor-panel hidden"
    role="dialog"
    aria-label="AI tutor"
  >
    <span class="tutor-corner tutor-corner-tl" aria-hidden="true"></span>
    <span class="tutor-corner tutor-corner-tr" aria-hidden="true"></span>
    <span class="tutor-corner tutor-corner-bl" aria-hidden="true"></span>
    <span class="tutor-corner tutor-corner-br" aria-hidden="true"></span>

    <header class="tutor-head">
      <div class="flex items-center gap-2.5 min-w-0">
        <span class="tutor-crest" aria-hidden="true">
          <span class="tutor-crest-pulse"></span>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 2 9 9l-7 3 7 3 3 7 3-7 7-3-7-3z"/>
          </svg>
        </span>
        <div class="min-w-0">
          <p class="tutor-head-title">AI · TUTOR</p>
          <p class="tutor-head-meta">LLaMA&nbsp;3.1&nbsp;·&nbsp;CF&nbsp;Edge</p>
        </div>
      </div>
      <div class="flex items-center gap-1">
        <button type="button" data-tutor-reset class="tutor-head-btn" aria-label="Clear conversation">CLR</button>
        <button type="button" data-tutor-close aria-label="Close tutor" class="tutor-head-btn">
          <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M18 6 6 18M6 6l12 12"/></svg>
        </button>
      </div>
    </header>

    <div
      data-tutor-log
      class="tutor-log"
      aria-live="polite"
    >
      <div data-tutor-welcome class="tutor-welcome">
        <span class="tutor-welcome-tag">//&nbsp;ready</span>
        <span>Ask about this guide, tap a shortcut, or hover any paragraph to re-explain it.</span>
      </div>
    </div>

    <div data-tutor-offline class="tutor-alert hidden">
      Tutor offline. <code class="font-mono">PUBLIC_AI_TUTOR_URL</code> not configured.
    </div>

    <div data-tutor-actions class="tutor-actions">
      <button type="button" data-tutor-action="simpler" class="tutor-chip">
        <span class="tutor-chip-dot"></span>Explain simpler
      </button>
      <button type="button" data-tutor-action="quiz" class="tutor-chip">
        <span class="tutor-chip-dot"></span>Practice questions
      </button>
      <button type="button" data-tutor-action="summary" class="tutor-chip">
        <span class="tutor-chip-dot"></span>Key takeaways
      </button>
    </div>

    <form data-tutor-form class="tutor-form">
      <label class="sr-only" for="tutor-input">Question</label>
      <textarea
        id="tutor-input"
        data-tutor-input
        rows="1"
        placeholder="> transmit query..."
        class="tutor-input"
      ></textarea>
      <button
        type="submit"
        data-tutor-send
        aria-label="Send"
        class="tutor-send"
      >
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="m5 12 14-7-7 14-2-5z"/>
        </svg>
      </button>
    </form>
  </div>
</div>

<style is:global>
  /* ---------- Futuristic AI tutor ---------- */
  .tutor-widget {
    --tutor-accent: 220 38 38;        /* red-600 */
    --tutor-accent-glow: 239 68 68;   /* red-500 */
    --tutor-bg: 255 255 255;
    --tutor-ink: 24 24 27;
    --tutor-edge: 228 228 231;
  }
  .dark .tutor-widget {
    --tutor-bg: 9 9 11;               /* near-black */
    --tutor-ink: 244 244 245;
    --tutor-edge: 39 39 42;
  }

  /* FAB --------------------------------------------------------------- */
  .tutor-fab {
    position: fixed; right: 20px; bottom: 20px; z-index: 40;
    display: inline-flex; align-items: center; gap: 10px;
    padding: 10px 16px 10px 10px;
    border-radius: 9999px;
    background: linear-gradient(135deg, rgb(var(--tutor-ink)) 0%, rgb(40 20 22) 60%, rgb(var(--tutor-accent)) 100%);
    color: white;
    border: 1px solid rgba(var(--tutor-accent-glow), 0.55);
    box-shadow:
      0 0 0 1px rgba(var(--tutor-accent), 0.25),
      0 10px 40px -8px rgba(var(--tutor-accent), 0.5),
      0 0 28px -4px rgba(var(--tutor-accent-glow), 0.35);
    cursor: pointer;
    transition: transform 200ms ease, box-shadow 200ms ease;
  }
  .tutor-fab:hover {
    transform: translateY(-1px) scale(1.02);
    box-shadow:
      0 0 0 1px rgba(var(--tutor-accent), 0.4),
      0 14px 48px -6px rgba(var(--tutor-accent), 0.6),
      0 0 44px -4px rgba(var(--tutor-accent-glow), 0.55);
  }
  .tutor-fab:focus-visible {
    outline: 2px solid rgba(var(--tutor-accent-glow), 0.9);
    outline-offset: 3px;
  }
  .tutor-fab-ring {
    position: absolute; inset: -6px; border-radius: 9999px;
    border: 1px solid rgba(var(--tutor-accent-glow), 0.5);
    animation: tutor-ring 2.6s ease-out infinite;
    pointer-events: none;
  }
  .tutor-fab-core {
    display: inline-flex; align-items: center; justify-content: center;
    height: 34px; width: 34px; border-radius: 9999px;
    background: rgba(0,0,0,0.35);
    border: 1px solid rgba(255,255,255,0.18);
    color: rgb(254 226 226);
    backdrop-filter: blur(6px);
  }
  .tutor-fab-label { display: inline-flex; flex-direction: column; line-height: 1; gap: 3px; }
  .tutor-fab-label-top { font-size: 10px; font-weight: 700; letter-spacing: 0.2em; font-family: ui-monospace, SFMono-Regular, Menlo, monospace; }
  .tutor-fab-label-bot {
    font-size: 10px; letter-spacing: 0.12em;
    color: rgba(255,255,255,0.75);
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    position: relative; padding-left: 9px;
  }
  .tutor-fab-label-bot::before {
    content: ''; position: absolute; left: 0; top: 50%;
    height: 6px; width: 6px; margin-top: -3px; border-radius: 9999px;
    background: rgb(74 222 128);
    box-shadow: 0 0 10px rgb(74 222 128);
    animation: tutor-pulse 1.8s ease-in-out infinite;
  }

  @keyframes tutor-ring {
    0%   { transform: scale(1);    opacity: 0.7; }
    70%  { transform: scale(1.25); opacity: 0;   }
    100% { transform: scale(1.25); opacity: 0;   }
  }
  @keyframes tutor-pulse {
    0%, 100% { opacity: 1;   transform: scale(1); }
    50%      { opacity: 0.4; transform: scale(0.78); }
  }

  /* Panel ------------------------------------------------------------- */
  .tutor-panel {
    position: fixed; z-index: 50;
    right: 16px; bottom: 16px; left: 16px;
    max-height: calc(100vh - 2rem);
    display: flex; flex-direction: column;
    border-radius: 18px; overflow: hidden;
    background:
      radial-gradient(120% 90% at 100% 0%, rgba(var(--tutor-accent), 0.14), transparent 60%),
      linear-gradient(180deg, rgba(var(--tutor-bg), 0.85), rgba(var(--tutor-bg), 0.92));
    backdrop-filter: blur(18px) saturate(130%);
    -webkit-backdrop-filter: blur(18px) saturate(130%);
    border: 1px solid rgba(var(--tutor-accent-glow), 0.28);
    color: rgb(var(--tutor-ink));
    box-shadow:
      0 0 0 1px rgba(var(--tutor-accent), 0.08),
      0 30px 80px -20px rgba(0,0,0,0.45),
      0 0 60px -12px rgba(var(--tutor-accent-glow), 0.2);
    animation: tutor-panel-in 180ms cubic-bezier(.2,.8,.2,1);
  }
  @media (min-width: 640px) {
    .tutor-panel { left: auto; width: 400px; }
  }
  @media (min-width: 768px) {
    .tutor-panel { width: 440px; }
  }
  @keyframes tutor-panel-in {
    from { opacity: 0; transform: translateY(8px) scale(0.98); }
    to   { opacity: 1; transform: translateY(0)   scale(1);    }
  }

  /* HUD corner brackets */
  .tutor-corner {
    position: absolute; width: 14px; height: 14px; pointer-events: none;
    border-color: rgba(var(--tutor-accent-glow), 0.7);
  }
  .tutor-corner-tl { top: 8px;    left: 8px;    border-top: 2px solid; border-left: 2px solid;    border-top-left-radius: 4px; }
  .tutor-corner-tr { top: 8px;    right: 8px;   border-top: 2px solid; border-right: 2px solid;   border-top-right-radius: 4px; }
  .tutor-corner-bl { bottom: 8px; left: 8px;    border-bottom: 2px solid; border-left: 2px solid; border-bottom-left-radius: 4px; }
  .tutor-corner-br { bottom: 8px; right: 8px;   border-bottom: 2px solid; border-right: 2px solid;border-bottom-right-radius: 4px; }

  /* Header ------------------------------------------------------------ */
  .tutor-head {
    display: flex; align-items: center; justify-content: space-between; gap: 12px;
    padding: 12px 16px;
    border-bottom: 1px solid rgba(var(--tutor-edge), 0.9);
    background: linear-gradient(90deg, rgba(var(--tutor-accent), 0.08), transparent 60%);
  }
  .tutor-crest {
    position: relative;
    display: inline-flex; align-items: center; justify-content: center;
    height: 34px; width: 34px; border-radius: 10px;
    background: linear-gradient(135deg, rgb(var(--tutor-accent)), rgb(127 29 29));
    color: white;
    box-shadow: 0 0 16px -2px rgba(var(--tutor-accent-glow), 0.7), inset 0 0 0 1px rgba(255,255,255,0.18);
  }
  .tutor-crest svg { width: 16px; height: 16px; }
  .tutor-crest-pulse {
    position: absolute; inset: -3px; border-radius: 12px;
    border: 1px solid rgba(var(--tutor-accent-glow), 0.6);
    animation: tutor-ring 2.4s ease-out infinite;
  }
  .tutor-head-title {
    font-size: 11px; font-weight: 700; letter-spacing: 0.22em;
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    line-height: 1;
    color: rgb(var(--tutor-ink));
  }
  .tutor-head-meta {
    margin-top: 5px; font-size: 10px; letter-spacing: 0.14em;
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    color: rgba(113, 113, 122, 0.9);
  }
  .dark .tutor-head-meta { color: rgba(161, 161, 170, 0.85); }
  .tutor-head-btn {
    display: inline-flex; align-items: center; justify-content: center;
    min-width: 28px; height: 26px; padding: 0 7px;
    border-radius: 6px;
    font-size: 10px; font-weight: 700; letter-spacing: 0.14em;
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    color: rgba(113, 113, 122, 0.95);
    background: transparent;
    border: 1px solid transparent;
    cursor: pointer;
    transition: all 120ms ease;
  }
  .tutor-head-btn:hover {
    color: rgb(var(--tutor-accent));
    border-color: rgba(var(--tutor-accent-glow), 0.45);
    background: rgba(var(--tutor-accent), 0.06);
  }
  .dark .tutor-head-btn { color: rgba(161,161,170,0.9); }
  .dark .tutor-head-btn:hover {
    color: rgb(254 202 202);
    background: rgba(var(--tutor-accent), 0.14);
  }

  /* Log --------------------------------------------------------------- */
  .tutor-log {
    flex: 1; overflow-y: auto;
    padding: 14px 16px; min-height: 180px;
    display: flex; flex-direction: column; gap: 10px;
    font-size: 13.5px; line-height: 1.55;
    background:
      linear-gradient(transparent 95%, rgba(var(--tutor-edge), 0.6) 95%) 0 0 / 100% 28px,
      transparent;
  }
  .tutor-welcome {
    font-size: 12px; color: rgba(113,113,122,0.9);
    display: flex; flex-direction: column; gap: 4px;
  }
  .dark .tutor-welcome { color: rgba(161,161,170,0.85); }
  .tutor-welcome-tag {
    font-size: 10px; letter-spacing: 0.18em;
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    color: rgb(var(--tutor-accent));
  }

  /* Alert ------------------------------------------------------------- */
  .tutor-alert {
    margin: 10px 14px; padding: 10px 12px;
    border-radius: 10px;
    border: 1px dashed rgba(var(--tutor-accent-glow), 0.45);
    background: rgba(var(--tutor-accent), 0.06);
    font-size: 11px; letter-spacing: 0.04em;
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    color: rgb(var(--tutor-accent));
  }
  .dark .tutor-alert { color: rgb(252 165 165); }

  /* Actions ----------------------------------------------------------- */
  .tutor-actions {
    display: flex; flex-wrap: wrap; gap: 6px;
    padding: 10px 12px 6px;
    border-top: 1px solid rgba(var(--tutor-edge), 0.75);
  }
  .tutor-chip {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 5px 11px; border-radius: 9999px;
    font-size: 10.5px; font-weight: 600; letter-spacing: 0.08em;
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    text-transform: uppercase;
    color: rgb(63 63 70);
    background: rgba(var(--tutor-bg), 0.6);
    border: 1px solid rgba(var(--tutor-edge), 0.95);
    cursor: pointer;
    transition: all 140ms ease;
  }
  .dark .tutor-chip { color: rgb(212 212 216); background: rgba(24,24,27,0.5); }
  .tutor-chip:hover {
    color: white;
    background: rgb(var(--tutor-accent));
    border-color: rgb(var(--tutor-accent));
    box-shadow: 0 0 14px -2px rgba(var(--tutor-accent-glow), 0.6);
  }
  .tutor-chip:disabled { opacity: 0.5; cursor: not-allowed; }
  .tutor-chip-dot {
    display: inline-block; height: 6px; width: 6px; border-radius: 9999px;
    background: rgb(var(--tutor-accent));
    box-shadow: 0 0 6px rgb(var(--tutor-accent-glow));
  }
  .tutor-chip:hover .tutor-chip-dot { background: white; box-shadow: 0 0 8px white; }

  /* Form -------------------------------------------------------------- */
  .tutor-form {
    display: flex; align-items: flex-end; gap: 8px;
    padding: 10px 12px 12px;
    border-top: 1px solid rgba(var(--tutor-edge), 0.6);
  }
  .tutor-input {
    flex: 1; resize: none; max-height: 96px;
    padding: 9px 12px;
    border-radius: 10px;
    border: 1px solid rgba(var(--tutor-edge), 0.95);
    background: rgba(var(--tutor-bg), 0.85);
    color: rgb(var(--tutor-ink));
    font-size: 13px; font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    outline: none;
    transition: border-color 140ms ease, box-shadow 140ms ease;
  }
  .tutor-input:focus {
    border-color: rgba(var(--tutor-accent-glow), 0.7);
    box-shadow: 0 0 0 3px rgba(var(--tutor-accent), 0.18);
  }
  .tutor-input::placeholder { color: rgba(113,113,122,0.75); }
  .dark .tutor-input { background: rgba(24,24,27,0.7); }
  .tutor-send {
    display: inline-flex; align-items: center; justify-content: center;
    height: 36px; width: 36px; border-radius: 10px;
    background: linear-gradient(135deg, rgb(var(--tutor-accent)), rgb(127 29 29));
    color: white; border: 0; cursor: pointer;
    box-shadow: 0 6px 16px -4px rgba(var(--tutor-accent), 0.5);
    transition: transform 120ms ease, box-shadow 120ms ease, opacity 120ms ease;
  }
  .tutor-send:hover { transform: translateY(-1px); box-shadow: 0 10px 22px -6px rgba(var(--tutor-accent-glow), 0.7); }
  .tutor-send:disabled { opacity: 0.5; cursor: not-allowed; transform: none; box-shadow: none; }

  /* Hover-explain outline: applied to the prose block currently being hovered while the tutor is open. */
  .tutor-explain-target {
    outline: 2px dashed rgba(185, 28, 28, 0.55);
    outline-offset: 4px;
    border-radius: 6px;
    transition: outline-color 120ms ease-out;
  }
  .dark .tutor-explain-target {
    outline-color: rgba(248, 113, 113, 0.55);
  }

  /* The floating action bar above a hovered block. */
  [data-tutor-hover-menu] {
    position: absolute;
    z-index: 60;
    display: none;
    align-items: center;
    gap: 6px;
    padding: 6px;
    border-radius: 9999px;
    background: white;
    border: 1px solid rgb(228 228 231);
    box-shadow: 0 12px 32px -10px rgba(0,0,0,0.20), 0 2px 6px rgba(0,0,0,0.08);
    font: 600 12px/1 ui-sans-serif, system-ui, sans-serif;
    color: rgb(63 63 70);
    pointer-events: auto;
    animation: tutorFadeIn 140ms ease-out;
  }
  .dark [data-tutor-hover-menu] {
    background: rgb(24 24 27);
    border-color: rgb(63 63 70);
    color: rgb(228 228 231);
  }
  [data-tutor-hover-menu].is-open { display: inline-flex; }

  [data-tutor-hover-menu] button {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 14px;
    min-height: 32px;
    border-radius: 9999px;
    background: transparent;
    border: 0;
    color: inherit;
    cursor: pointer;
    font-weight: 600;
    transition: background-color 120ms ease, color 120ms ease;
  }
  [data-tutor-hover-menu] button:hover {
    background: rgb(254 226 226);
    color: rgb(127 29 29);
  }
  .dark [data-tutor-hover-menu] button:hover {
    background: rgba(127, 29, 29, 0.45);
    color: rgb(254 226 226);
  }

  /* Invisible bridge below the menu so the cursor can travel from a hovered
     block up into the menu without ever leaving a hover region. */
  [data-tutor-hover-menu]::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    top: 100%;
    height: 14px;
  }

  @keyframes tutorFadeIn {
    from { opacity: 0; transform: translateY(2px); }
    to   { opacity: 1; transform: translateY(0); }
  }
</style>

<script>
  type Msg = { role: 'user' | 'assistant'; content: string };

  const escape = (s: string) =>
    s.replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' })[c]!);

  const renderMarkdown = (src: string) => {
    const esc = escape(src);
    const withInline = esc
      .replace(/`([^`]+)`/g, '<code class="font-mono text-[0.85em] bg-ink-100 dark:bg-ink-800 px-1 rounded">$1</code>')
      .replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>')
      .replace(/(^|[^*])\*([^*\n]+)\*/g, '$1<em>$2</em>');
    return withInline
      .split(/\n{2,}/)
      .map((p) => `<p>${p.replace(/\n/g, '<br/>')}</p>`)
      .join('');
  };

  const getGuideContext = (maxChars = 3000): string => {
    const prose = document.querySelector<HTMLElement>('article .prose');
    if (!prose) return '';
    const text = (prose.innerText || '').replace(/\s+/g, ' ').trim();
    return text.length > maxChars ? text.slice(0, maxChars) + '...' : text;
  };

  const ACTION_PROMPTS: Record<string, string> = {
    simpler: 'Explain the main ideas of this guide in simpler words, like you are talking to a middle school student. Use short sentences and one concrete analogy. Under 150 words.',
    quiz: 'Generate 3 multiple-choice practice questions about this guide. Format each as:\n\n1. Question\n   A) choice\n   B) choice\n   C) choice\n   D) choice\n   **Answer:** X, one-sentence reason why.',
    summary: 'Summarize this guide as 5 short numbered takeaways. Each under 20 words. No intro, just the list.',
  };

  // Selectors a prose block must match to be eligible for hover-to-explain.
  // Lives inside <article class="...prose">, NOT inside .not-prose (which marks
  // our interactive widgets like Quiz / Flashcards / Callouts).
  const HOVER_BLOCK_SELECTOR = 'p, li, blockquote, pre';

  const init = () => {
    const root = document.querySelector<HTMLElement>('[data-tutor-root]');
    if (!root) return;
    if ((root as any).__tutorInit) return;
    (root as any).__tutorInit = true;

    const endpoint = root.dataset.tutorEndpoint || '';
    const guideTitle = root.dataset.tutorGuide || '';
    const fab = root.querySelector<HTMLButtonElement>('[data-tutor-fab]')!;
    const panel = root.querySelector<HTMLElement>('[data-tutor-panel]')!;
    const closeBtn = root.querySelector<HTMLButtonElement>('[data-tutor-close]')!;
    const log = root.querySelector<HTMLElement>('[data-tutor-log]')!;
    const welcome = root.querySelector<HTMLElement>('[data-tutor-welcome]');
    const form = root.querySelector<HTMLFormElement>('[data-tutor-form]')!;
    const input = root.querySelector<HTMLTextAreaElement>('[data-tutor-input]')!;
    const sendBtn = root.querySelector<HTMLButtonElement>('[data-tutor-send]')!;
    const resetBtn = root.querySelector<HTMLButtonElement>('[data-tutor-reset]')!;
    const offline = root.querySelector<HTMLElement>('[data-tutor-offline]')!;
    const actions = root.querySelector<HTMLElement>('[data-tutor-actions]')!;

    // Tutor-open state lives on <html> so the document-level hover listeners
    // (which may have been attached on a previous page and survived a view
    // transition) can read fresh state instead of stale closure variables.
    const open = () => {
      panel.classList.remove('hidden');
      fab.classList.add('hidden');
      document.documentElement.classList.add('tutor-is-open');
      setTimeout(() => input.focus(), 50);
    };
    const close = () => {
      panel.classList.add('hidden');
      fab.classList.remove('hidden');
      document.documentElement.classList.remove('tutor-is-open');
      hideHoverMenuGlobal();
    };

    fab.addEventListener('click', open);
    closeBtn.addEventListener('click', close);
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !panel.classList.contains('hidden')) close();
    });

    if (!endpoint) {
      offline.classList.remove('hidden');
      form.classList.add('hidden');
      actions.classList.add('hidden');
      return;
    }

    const history: Msg[] = [];
    let sentContextOnce = false;

    const appendMessage = (role: Msg['role'], content: string): HTMLElement => {
      if (welcome && !welcome.classList.contains('hidden')) welcome.classList.add('hidden');
      const wrap = document.createElement('div');
      wrap.className = role === 'user' ? 'flex justify-end' : 'flex justify-start';
      const bubble = document.createElement('div');
      bubble.className = role === 'user'
        ? 'max-w-[85%] rounded-2xl rounded-br-sm bg-accent-600 text-white px-3 py-2 text-sm'
        : 'max-w-[85%] rounded-2xl rounded-bl-sm bg-ink-100 dark:bg-ink-800 text-ink-900 dark:text-ink-100 px-3 py-2 text-sm';
      bubble.innerHTML = renderMarkdown(content || '…');
      wrap.appendChild(bubble);
      log.appendChild(wrap);
      log.scrollTop = log.scrollHeight;
      return bubble;
    };

    const setBusy = (busy: boolean) => {
      sendBtn.disabled = busy;
      input.disabled = busy;
      actions.querySelectorAll('button').forEach((b) => (b as HTMLButtonElement).disabled = busy);
    };

    const parseSSELine = (line: string): string | null => {
      if (!line.startsWith('data:')) return null;
      const payload = line.slice(5).trim();
      if (!payload || payload === '[DONE]') return null;
      try {
        const obj = JSON.parse(payload);
        if (typeof obj.response === 'string') return obj.response;
        if (typeof obj.delta === 'string') return obj.delta;
        return null;
      } catch {
        return null;
      }
    };

    // ask() sends `prompt` to the model. If `displayLabel` is provided it is
    // shown as the user-side bubble in the chat log instead of the raw prompt
    // (used by the hover-to-explain feature so the chat doesn't get cluttered
    // with copy-pasted passages).
    const ask = async (prompt: string, displayLabel?: string) => {
      history.push({ role: 'user', content: prompt });
      appendMessage('user', displayLabel ?? prompt);
      const bubble = appendMessage('assistant', '');
      let acc = '';
      setBusy(true);

      const body: Record<string, unknown> = {
        messages: history,
        guideTitle: guideTitle || undefined,
      };
      if (!sentContextOnce) {
        const ctx = getGuideContext();
        if (ctx) body.guideContext = ctx;
        sentContextOnce = true;
      }

      try {
        const res = await fetch(`${endpoint.replace(/\/$/, '')}/tutor`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(body),
        });
        if (!res.ok) {
          const err = await res.json().catch(() => ({ error: `HTTP ${res.status}` }));
          bubble.innerHTML = renderMarkdown(`*${err.error ?? 'Something went wrong.'}*`);
          return;
        }
        if (!res.body) {
          bubble.innerHTML = renderMarkdown('*No response body.*');
          return;
        }
        const reader = res.body.getReader();
        const decoder = new TextDecoder();
        let buf = '';
        while (true) {
          const { value, done } = await reader.read();
          if (done) break;
          buf += decoder.decode(value, { stream: true });
          const lines = buf.split('\n');
          buf = lines.pop() ?? '';
          for (const line of lines) {
            const chunk = parseSSELine(line);
            if (chunk) {
              acc += chunk;
              bubble.innerHTML = renderMarkdown(acc);
              log.scrollTop = log.scrollHeight;
            }
          }
        }
        history.push({ role: 'assistant', content: acc });
      } catch {
        bubble.innerHTML = renderMarkdown('*Network error. Try again.*');
      } finally {
        setBusy(false);
        if (!input.disabled) input.focus();
      }
    };

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const q = input.value.trim();
      if (!q) return;
      input.value = '';
      ask(q);
    });

    input.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' && !e.shiftKey) {
        e.preventDefault();
        form.requestSubmit();
      }
    });

    resetBtn.addEventListener('click', () => {
      history.length = 0;
      sentContextOnce = false;
      log.innerHTML = '';
      if (welcome) {
        welcome.classList.remove('hidden');
        log.appendChild(welcome);
      }
      input.focus();
    });

    actions.querySelectorAll<HTMLButtonElement>('[data-tutor-action]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const key = btn.dataset.tutorAction ?? '';
        const prompt = ACTION_PROMPTS[key];
        if (prompt) ask(prompt);
      });
    });

    // Register THIS page's ask/open with the document-global hover system.
    // Re-assigning each navigation means stale closures from old pages are
    // discarded instead of stacking up as dead listeners.
    g_currentAsk = (prompt, label) => {
      if (panel.classList.contains('hidden')) open();
      ask(prompt, label);
    };
  };

  /* ---------- Hover-to-explain (document-global wiring, attached once) ----- */
  // Lives outside init() so listeners aren't duplicated across view-transition
  // navigations and so the gate is the live <html> class, not a stale closure
  // variable. Also handles the "menu disappears before I can click" gap with
  // a 220ms hide delay plus an invisible CSS bridge under the menu.

  let g_hoverEl: HTMLElement | null = null;
  let g_hoverMenu: HTMLElement | null = null;
  let g_hideTimer: number | null = null;
  // Re-assigned by each page's init() so the hover menu always routes to the
  // current page's chat panel (not a stale one from a previous navigation).
  let g_currentAsk: ((prompt: string, label?: string) => void) | null = null;

  const cancelHide = () => {
    if (g_hideTimer != null) { clearTimeout(g_hideTimer); g_hideTimer = null; }
  };

  const hideHoverMenuGlobal = () => {
    cancelHide();
    if (g_hoverEl) g_hoverEl.classList.remove('tutor-explain-target');
    g_hoverEl = null;
    if (g_hoverMenu) g_hoverMenu.classList.remove('is-open');
  };

  const scheduleHide = () => {
    cancelHide();
    g_hideTimer = window.setTimeout(() => hideHoverMenuGlobal(), 220);
  };

  const buildHoverMenu = (): HTMLElement => {
    const m = document.createElement('div');
    m.setAttribute('data-tutor-hover-menu', '');
    m.setAttribute('role', 'toolbar');
    m.setAttribute('aria-label', 'Re-explain this passage');
    m.innerHTML = `
      <button type="button" data-explain="simpler" title="Re-explain in simpler words">
        <span aria-hidden="true">🧠</span><span>Simpler</span>
      </button>
      <button type="button" data-explain="caveman" title="Re-explain in caveman terms">
        <span aria-hidden="true">🦴</span><span>Caveman</span>
      </button>
    `;
    m.addEventListener('mouseenter', cancelHide);
    m.addEventListener('mouseleave', scheduleHide);
    m.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest('button[data-explain]') as HTMLButtonElement | null;
      if (!btn || !g_hoverEl) return;
      const kind = btn.dataset.explain as 'simpler' | 'caveman';
      const passage = (g_hoverEl.innerText || '').replace(/\s+/g, ' ').trim();
      if (!passage) return;
      hideHoverMenuGlobal();
      // No registered handler means init() bailed before wiring up (e.g. the
      // tutor endpoint env var isn't set, so the panel is showing "Tutor not
      // configured"). Nothing useful to do here.
      if (!g_currentAsk) return;
      const truncated = passage.length > 60 ? passage.slice(0, 60) + '...' : passage;
      const label = kind === 'simpler'
        ? `🧠 Explain simpler: "${truncated}"`
        : `🦴 In caveman terms: "${truncated}"`;
      const prompt = kind === 'simpler'
        ? `Re-explain the passage below in really simple words, like you're talking to a 7th-grader who has never seen this material. Use one short concrete analogy. 100 words maximum.\n\nPassage:\n"""\n${passage}\n"""`
        : `Re-explain the passage below in caveman speak. Short blunt sentences. Tiny vocabulary. Example tone: "Sun hot. Plant eat sun. Plant make food." Be funny but keep the facts correct. 100 words maximum.\n\nPassage:\n"""\n${passage}\n"""`;
      g_currentAsk(prompt, label);
    });
    document.body.appendChild(m);
    return m;
  };

  const positionHoverMenu = (target: HTMLElement) => {
    if (!g_hoverMenu) return;
    g_hoverMenu.classList.add('is-open');
    const r = target.getBoundingClientRect();
    const mw = g_hoverMenu.offsetWidth || 200;
    const mh = g_hoverMenu.offsetHeight || 40;
    // Sit the menu so its bottom OVERLAPS the top of the block by 6px. That
    // way moving the cursor up from the text never crosses an empty gap.
    const overlap = 6;
    const top = window.scrollY + r.top - mh + overlap;
    const left = Math.max(8, window.scrollX + r.right - mw);
    g_hoverMenu.style.top = `${Math.max(window.scrollY + 4, top)}px`;
    g_hoverMenu.style.left = `${left}px`;
  };

  const showHoverMenu = (target: HTMLElement) => {
    cancelHide();
    if (!g_hoverMenu) g_hoverMenu = buildHoverMenu();
    if (g_hoverEl && g_hoverEl !== target) g_hoverEl.classList.remove('tutor-explain-target');
    g_hoverEl = target;
    target.classList.add('tutor-explain-target');
    positionHoverMenu(target);
  };

  const isEligibleHoverTarget = (el: Element | null): el is HTMLElement => {
    if (!el) return false;
    if (!(el instanceof HTMLElement)) return false;
    if (el.closest('[data-tutor-root]')) return false;
    if (el.closest('[data-tutor-hover-menu]')) return false;
    if (el.closest('.not-prose')) return false;
    if (!el.closest('article .prose')) return false;
    return true;
  };

  const wireHoverGlobalOnce = () => {
    const w = window as any;
    if (w.__tutorHoverWired) return;
    w.__tutorHoverWired = true;

    document.addEventListener('mouseover', (e) => {
      if (!document.documentElement.classList.contains('tutor-is-open')) return;
      const target = (e.target as HTMLElement | null)?.closest(HOVER_BLOCK_SELECTOR) as HTMLElement | null;
      if (!isEligibleHoverTarget(target)) return;
      const text = (target.innerText || '').trim();
      if (text.length < 20) return;
      if (target === g_hoverEl) {
        cancelHide();
        return;
      }
      showHoverMenu(target);
    });

    document.addEventListener('mouseout', (e) => {
      if (!g_hoverEl) return;
      const related = e.relatedTarget as HTMLElement | null;
      if (related && (g_hoverEl.contains(related) || related.closest('[data-tutor-hover-menu]'))) return;
      // Don't yank it instantly: give the cursor time to land on the menu.
      scheduleHide();
    });

    // Reposition on scroll/resize so the menu tracks the block.
    let raf = 0;
    const reflow = () => {
      if (!g_hoverEl || !g_hoverMenu?.classList.contains('is-open')) return;
      cancelAnimationFrame(raf);
      raf = requestAnimationFrame(() => positionHoverMenu(g_hoverEl!));
    };
    window.addEventListener('scroll', reflow, { passive: true });
    window.addEventListener('resize', reflow);
  };
  wireHoverGlobalOnce();

  init();
  document.addEventListener('astro:after-swap', init);
</script>
