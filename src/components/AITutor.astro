---
// Streaming chat tutor backed by a Cloudflare Worker (Workers AI).
// Login-gated via currentUser(). Set PUBLIC_AI_TUTOR_URL to the Worker URL.
interface Props {
  guideTitle?: string;
  title?: string;
  placeholder?: string;
}
const {
  guideTitle,
  title = 'Ask the tutor',
  placeholder = 'Ask a question about this guide...',
} = Astro.props;

const id = 'tutor-' + Math.random().toString(36).slice(2, 9);
const endpoint = import.meta.env.PUBLIC_AI_TUTOR_URL as string | undefined;
---

<section
  class="not-prose my-8 surface rounded-2xl p-6 shadow-soft"
  data-tutor-root
  id={id}
  data-tutor-endpoint={endpoint ?? ''}
  data-tutor-guide={guideTitle ?? ''}
>
  <header class="flex items-center justify-between gap-3 mb-4">
    <div class="flex items-center gap-3">
      <span class="inline-flex items-center justify-center h-9 w-9 rounded-xl bg-gradient-to-br from-accent-600 to-accent-800 text-white font-serif font-semibold">AI</span>
      <div>
        <h3 class="font-serif text-lg font-semibold leading-none">{title}</h3>
        <p class="text-xs text-ink-500 mt-1">Runs on Cloudflare Workers AI. Powered by Llama 3.1.</p>
      </div>
    </div>
    <button type="button" data-tutor-reset class="text-xs text-ink-500 hover:text-accent-700 dark:hover:text-accent-300">Clear</button>
  </header>

  <div
    data-tutor-log
    class="min-h-[120px] max-h-[420px] overflow-y-auto space-y-3 mb-4 text-sm leading-relaxed"
    aria-live="polite"
  ></div>

  <div data-tutor-gate class="hidden rounded-lg border border-dashed border-ink-200 dark:border-ink-700 p-4 text-sm text-ink-600 dark:text-ink-300">
    <a href="/login" class="text-accent-700 dark:text-accent-300 underline">Log in</a>
    or <a href="/signup" class="text-accent-700 dark:text-accent-300 underline">create a free account</a>
    to chat with the tutor.
  </div>

  <div data-tutor-offline class="hidden rounded-lg border border-amber-300 dark:border-amber-700 bg-amber-50 dark:bg-amber-900/30 p-4 text-sm text-amber-900 dark:text-amber-200">
    The tutor is not configured on this deployment. Ask a site admin to set
    <code class="font-mono">PUBLIC_AI_TUTOR_URL</code>.
  </div>

  <form data-tutor-form class="flex items-end gap-2">
    <label class="sr-only" for={`${id}-input`}>Question</label>
    <textarea
      id={`${id}-input`}
      data-tutor-input
      rows="2"
      placeholder={placeholder}
      class="flex-1 resize-none rounded-lg border border-ink-200 dark:border-ink-800 bg-white dark:bg-ink-950 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-accent-400"
    ></textarea>
    <button
      type="submit"
      data-tutor-send
      class="inline-flex items-center gap-1.5 px-4 py-2 rounded-lg bg-accent-600 text-white text-sm font-medium hover:bg-accent-700 disabled:opacity-50 disabled:cursor-not-allowed"
    >
      Ask
    </button>
  </form>
</section>

<script>
  import { currentUser } from '../lib/auth';

  type Msg = { role: 'user' | 'assistant'; content: string };

  const escape = (s: string) =>
    s.replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' })[c]!);

  // Light markdown: **bold**, *italic*, `code`, paragraphs.
  const renderMarkdown = (src: string) => {
    const esc = escape(src);
    const withInline = esc
      .replace(/`([^`]+)`/g, '<code class="font-mono text-[0.85em] bg-ink-100 dark:bg-ink-800 px-1 rounded">$1</code>')
      .replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>')
      .replace(/(^|[^*])\*([^*\n]+)\*/g, '$1<em>$2</em>');
    return withInline
      .split(/\n{2,}/)
      .map((p) => `<p>${p.replace(/\n/g, '<br/>')}</p>`)
      .join('');
  };

  const roots = document.querySelectorAll<HTMLElement>('[data-tutor-root]');
  roots.forEach((root) => {
    const endpoint = root.dataset.tutorEndpoint || '';
    const guideTitle = root.dataset.tutorGuide || '';
    const log = root.querySelector<HTMLElement>('[data-tutor-log]')!;
    const form = root.querySelector<HTMLFormElement>('[data-tutor-form]')!;
    const input = root.querySelector<HTMLTextAreaElement>('[data-tutor-input]')!;
    const sendBtn = root.querySelector<HTMLButtonElement>('[data-tutor-send]')!;
    const resetBtn = root.querySelector<HTMLButtonElement>('[data-tutor-reset]')!;
    const gate = root.querySelector<HTMLElement>('[data-tutor-gate]')!;
    const offline = root.querySelector<HTMLElement>('[data-tutor-offline]')!;

    const showGated = () => {
      gate.classList.remove('hidden');
      form.classList.add('hidden');
    };
    const showOffline = () => {
      offline.classList.remove('hidden');
      form.classList.add('hidden');
    };

    if (!endpoint) {
      showOffline();
      return;
    }
    if (!currentUser()) {
      showGated();
      return;
    }

    const history: Msg[] = [];

    const appendMessage = (role: Msg['role'], content: string): HTMLElement => {
      const wrap = document.createElement('div');
      wrap.className = role === 'user'
        ? 'flex justify-end'
        : 'flex justify-start';
      const bubble = document.createElement('div');
      bubble.className = role === 'user'
        ? 'max-w-[80%] rounded-2xl rounded-br-sm bg-accent-600 text-white px-4 py-2'
        : 'max-w-[80%] rounded-2xl rounded-bl-sm bg-ink-100 dark:bg-ink-800 text-ink-900 dark:text-ink-100 px-4 py-2';
      bubble.innerHTML = renderMarkdown(content || '…');
      wrap.appendChild(bubble);
      log.appendChild(wrap);
      log.scrollTop = log.scrollHeight;
      return bubble;
    };

    const setBusy = (busy: boolean) => {
      sendBtn.disabled = busy;
      input.disabled = busy;
      sendBtn.textContent = busy ? 'Thinking' : 'Ask';
    };

    const parseSSELine = (line: string): string | null => {
      if (!line.startsWith('data:')) return null;
      const payload = line.slice(5).trim();
      if (!payload || payload === '[DONE]') return null;
      try {
        const obj = JSON.parse(payload);
        if (typeof obj.response === 'string') return obj.response;
        if (typeof obj.delta === 'string') return obj.delta;
        return null;
      } catch {
        return null;
      }
    };

    const ask = async (question: string) => {
      history.push({ role: 'user', content: question });
      appendMessage('user', question);
      const bubble = appendMessage('assistant', '');
      let acc = '';
      setBusy(true);

      try {
        const res = await fetch(`${endpoint.replace(/\/$/, '')}/tutor`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ messages: history, guideTitle: guideTitle || undefined }),
        });
        if (!res.ok) {
          const err = await res.json().catch(() => ({ error: `HTTP ${res.status}` }));
          bubble.innerHTML = renderMarkdown(`*${err.error ?? 'Something went wrong.'}*`);
          return;
        }
        if (!res.body) {
          bubble.innerHTML = renderMarkdown('*No response body.*');
          return;
        }
        const reader = res.body.getReader();
        const decoder = new TextDecoder();
        let buf = '';
        while (true) {
          const { value, done } = await reader.read();
          if (done) break;
          buf += decoder.decode(value, { stream: true });
          const lines = buf.split('\n');
          buf = lines.pop() ?? '';
          for (const line of lines) {
            const chunk = parseSSELine(line);
            if (chunk) {
              acc += chunk;
              bubble.innerHTML = renderMarkdown(acc);
              log.scrollTop = log.scrollHeight;
            }
          }
        }
        history.push({ role: 'assistant', content: acc });
      } catch (e) {
        bubble.innerHTML = renderMarkdown(`*Network error. Try again.*`);
      } finally {
        setBusy(false);
        input.focus();
      }
    };

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const q = input.value.trim();
      if (!q) return;
      input.value = '';
      ask(q);
    });

    input.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' && !e.shiftKey) {
        e.preventDefault();
        form.requestSubmit();
      }
    });

    resetBtn.addEventListener('click', () => {
      history.length = 0;
      log.innerHTML = '';
      input.focus();
    });
  });
</script>
