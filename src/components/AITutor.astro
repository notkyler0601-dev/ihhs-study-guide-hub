---
// Floating bottom-right AI tutor. Chat + quick actions (explain simpler,
// generate practice questions, summarize). Pulls the surrounding guide's
// prose as context so answers stay grounded in what the student is reading.
//
// While the tutor panel is open, hovering a paragraph / list item /
// blockquote / code block inside the guide shows a soft outline plus a
// floating action bar with "Simpler" and "Caveman" buttons that re-explain
// just that passage.
//
// Open to everyone, no account needed. Requires PUBLIC_AI_TUTOR_URL
// pointing at the Cloudflare Worker in worker/.
interface Props {
  guideTitle?: string;
}
const { guideTitle } = Astro.props;
const endpoint = import.meta.env.PUBLIC_AI_TUTOR_URL as string | undefined;
---

<div
  class="no-print"
  data-tutor-root
  data-tutor-endpoint={endpoint ?? ''}
  data-tutor-guide={guideTitle ?? ''}
>
  <button
    type="button"
    data-tutor-fab
    aria-label="Open AI tutor"
    class="fixed bottom-5 right-5 z-40 inline-flex items-center gap-2 rounded-full bg-gradient-to-br from-accent-600 to-accent-800 text-white px-4 py-3 shadow-lift hover:scale-[1.03] transition-transform focus:outline-none focus:ring-4 focus:ring-accent-300/60"
  >
    <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
    </svg>
    <span class="text-sm font-medium">Ask tutor</span>
  </button>

  <div
    data-tutor-panel
    class="hidden fixed bottom-4 right-4 left-4 sm:left-auto sm:w-[380px] md:w-[420px] max-h-[calc(100vh-2rem)] z-50 flex flex-col rounded-2xl border border-ink-200 dark:border-ink-800 bg-white dark:bg-ink-950 shadow-lift overflow-hidden"
    role="dialog"
    aria-label="AI tutor"
  >
    <header class="flex items-center justify-between gap-3 px-4 py-3 border-b border-ink-200 dark:border-ink-800 bg-gradient-to-r from-accent-50 to-white dark:from-accent-950/40 dark:to-ink-950">
      <div class="flex items-center gap-2.5">
        <span class="inline-flex items-center justify-center h-8 w-8 rounded-lg bg-gradient-to-br from-accent-600 to-accent-800 text-white text-xs font-serif font-semibold">AI</span>
        <div>
          <p class="text-sm font-semibold leading-none">Tutor</p>
          <p class="text-[11px] text-ink-500 mt-1">Gemma 4 via Cloudflare</p>
        </div>
      </div>
      <div class="flex items-center gap-1">
        <button type="button" data-tutor-reset class="text-[11px] text-ink-500 hover:text-accent-700 dark:hover:text-accent-300 px-2 py-1 rounded hover:bg-ink-100 dark:hover:bg-ink-800">Clear</button>
        <button type="button" data-tutor-close aria-label="Close tutor" class="p-1 rounded hover:bg-ink-100 dark:hover:bg-ink-800 text-ink-500">
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M18 6 6 18M6 6l12 12"/></svg>
        </button>
      </div>
    </header>

    <div
      data-tutor-log
      class="flex-1 overflow-y-auto px-4 py-3 space-y-3 text-sm leading-relaxed min-h-[180px]"
      aria-live="polite"
    >
      <div data-tutor-welcome class="text-ink-500 text-xs">
        Ask about this guide, use a shortcut below, or hover any paragraph in the guide for one-click re-explains.
      </div>
    </div>

    <div data-tutor-offline class="hidden m-3 rounded-lg border border-amber-300 dark:border-amber-700 bg-amber-50 dark:bg-amber-900/30 p-3 text-xs text-amber-900 dark:text-amber-200">
      Tutor not configured. Set <code class="font-mono">PUBLIC_AI_TUTOR_URL</code>.
    </div>

    <div data-tutor-actions class="flex flex-wrap gap-1.5 px-3 pt-2 border-t border-ink-200 dark:border-ink-800">
      <button type="button" data-tutor-action="simpler" class="tutor-chip">Explain simpler</button>
      <button type="button" data-tutor-action="quiz" class="tutor-chip">Practice questions</button>
      <button type="button" data-tutor-action="summary" class="tutor-chip">Key takeaways</button>
    </div>

    <form data-tutor-form class="flex items-end gap-2 p-3 border-t border-ink-100 dark:border-ink-800">
      <label class="sr-only" for="tutor-input">Question</label>
      <textarea
        id="tutor-input"
        data-tutor-input
        rows="1"
        placeholder="Ask anything about this guide..."
        class="flex-1 resize-none rounded-lg border border-ink-200 dark:border-ink-800 bg-white dark:bg-ink-900 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-accent-400 max-h-24"
      ></textarea>
      <button
        type="submit"
        data-tutor-send
        aria-label="Send"
        class="inline-flex items-center justify-center h-9 w-9 rounded-lg bg-accent-600 text-white hover:bg-accent-700 disabled:opacity-50 disabled:cursor-not-allowed"
      >
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="m5 12 14-7-7 14-2-5z"/>
        </svg>
      </button>
    </form>
  </div>
</div>

<style is:global>
  .tutor-chip {
    @apply text-[11px] px-2.5 py-1 rounded-full border border-ink-200 dark:border-ink-700 text-ink-700 dark:text-ink-200 hover:border-accent-400 hover:text-accent-700 dark:hover:text-accent-300 transition-colors;
  }

  /* Three-dot typing indicator shown before the first token arrives. */
  .tutor-typing-dots {
    display: inline-flex;
    gap: 4px;
    align-items: center;
    padding: 4px 0;
  }
  .tutor-typing-dots > span {
    width: 6px;
    height: 6px;
    border-radius: 9999px;
    background: currentColor;
    opacity: 0.35;
    animation: tutorDotBounce 1.2s infinite ease-in-out;
  }
  .tutor-typing-dots > span:nth-child(2) { animation-delay: 0.15s; }
  .tutor-typing-dots > span:nth-child(3) { animation-delay: 0.3s; }
  @keyframes tutorDotBounce {
    0%, 80%, 100% { transform: translateY(0); opacity: 0.35; }
    40% { transform: translateY(-3px); opacity: 1; }
  }

  /* Blinking caret rendered at the end of the streaming reply. */
  .tutor-cursor {
    display: inline-block;
    width: 2px;
    height: 1em;
    margin-left: 2px;
    background: currentColor;
    vertical-align: text-bottom;
    animation: tutorCursorBlink 1.1s infinite step-end;
  }
  @keyframes tutorCursorBlink {
    0%, 50% { opacity: 1; }
    50.01%, 100% { opacity: 0; }
  }

  /* Subtle pulse on the assistant bubble while a reply is streaming. */
  .tutor-streaming {
    animation: tutorBubblePulse 1.8s ease-in-out infinite;
  }
  @keyframes tutorBubblePulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(185, 28, 28, 0); }
    50%      { box-shadow: 0 0 0 4px rgba(185, 28, 28, 0.10); }
  }
  .dark .tutor-streaming {
    animation-name: tutorBubblePulseDark;
  }
  @keyframes tutorBubblePulseDark {
    0%, 100% { box-shadow: 0 0 0 0 rgba(248, 113, 113, 0); }
    50%      { box-shadow: 0 0 0 4px rgba(248, 113, 113, 0.18); }
  }

  /* Hover-explain outline: applied to the prose block currently being hovered while the tutor is open. */
  .tutor-explain-target {
    outline: 2px dashed rgba(185, 28, 28, 0.55);
    outline-offset: 4px;
    border-radius: 6px;
    transition: outline-color 120ms ease-out;
  }
  .dark .tutor-explain-target {
    outline-color: rgba(248, 113, 113, 0.55);
  }

  /* The floating action bar above a hovered block. */
  [data-tutor-hover-menu] {
    position: absolute;
    z-index: 60;
    display: none;
    align-items: center;
    gap: 6px;
    padding: 6px;
    border-radius: 9999px;
    background: white;
    border: 1px solid rgb(228 228 231);
    box-shadow: 0 12px 32px -10px rgba(0,0,0,0.20), 0 2px 6px rgba(0,0,0,0.08);
    font: 600 12px/1 ui-sans-serif, system-ui, sans-serif;
    color: rgb(63 63 70);
    pointer-events: auto;
    animation: tutorFadeIn 140ms ease-out;
  }
  .dark [data-tutor-hover-menu] {
    background: rgb(24 24 27);
    border-color: rgb(63 63 70);
    color: rgb(228 228 231);
  }
  [data-tutor-hover-menu].is-open { display: inline-flex; }

  [data-tutor-hover-menu] button {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 14px;
    min-height: 32px;
    border-radius: 9999px;
    background: transparent;
    border: 0;
    color: inherit;
    cursor: pointer;
    font-weight: 600;
    transition: background-color 120ms ease, color 120ms ease;
  }
  [data-tutor-hover-menu] button:hover {
    background: rgb(254 226 226);
    color: rgb(127 29 29);
  }
  .dark [data-tutor-hover-menu] button:hover {
    background: rgba(127, 29, 29, 0.45);
    color: rgb(254 226 226);
  }

  /* Invisible bridge below the menu so the cursor can travel from a hovered
     block up into the menu without ever leaving a hover region. */
  [data-tutor-hover-menu]::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    top: 100%;
    height: 14px;
  }

  @keyframes tutorFadeIn {
    from { opacity: 0; transform: translateY(2px); }
    to   { opacity: 1; transform: translateY(0); }
  }
</style>

<script>
  type Msg = { role: 'user' | 'assistant'; content: string };

  const escape = (s: string) =>
    s.replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' })[c]!);

  const renderMarkdown = (src: string) => {
    const esc = escape(src);
    const withInline = esc
      .replace(/`([^`]+)`/g, '<code class="font-mono text-[0.85em] bg-ink-100 dark:bg-ink-800 px-1 rounded">$1</code>')
      .replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>')
      .replace(/(^|[^*])\*([^*\n]+)\*/g, '$1<em>$2</em>');
    return withInline
      .split(/\n{2,}/)
      .map((p) => `<p>${p.replace(/\n/g, '<br/>')}</p>`)
      .join('');
  };

  const getGuideContext = (maxChars = 3000): string => {
    const prose = document.querySelector<HTMLElement>('article .prose');
    if (!prose) return '';
    const text = (prose.innerText || '').replace(/\s+/g, ' ').trim();
    return text.length > maxChars ? text.slice(0, maxChars) + '...' : text;
  };

  const ACTION_PROMPTS: Record<string, string> = {
    simpler: 'Explain the main ideas of this guide in simpler words, like you are talking to a middle school student. Use short sentences and one concrete analogy. Under 150 words.',
    quiz: 'Generate 3 multiple-choice practice questions about this guide. Format each as:\n\n1. Question\n   A) choice\n   B) choice\n   C) choice\n   D) choice\n   **Answer:** X, one-sentence reason why.',
    summary: 'Summarize this guide as 5 short numbered takeaways. Each under 20 words. No intro, just the list.',
  };

  // Selectors a prose block must match to be eligible for hover-to-explain.
  // Lives inside <article class="...prose">, NOT inside .not-prose (which marks
  // our interactive widgets like Quiz / Flashcards / Callouts).
  const HOVER_BLOCK_SELECTOR = 'p, li, blockquote, pre';

  const init = () => {
    const root = document.querySelector<HTMLElement>('[data-tutor-root]');
    if (!root) return;
    if ((root as any).__tutorInit) return;
    (root as any).__tutorInit = true;

    const endpoint = root.dataset.tutorEndpoint || '';
    const guideTitle = root.dataset.tutorGuide || '';
    const fab = root.querySelector<HTMLButtonElement>('[data-tutor-fab]')!;
    const panel = root.querySelector<HTMLElement>('[data-tutor-panel]')!;
    const closeBtn = root.querySelector<HTMLButtonElement>('[data-tutor-close]')!;
    const log = root.querySelector<HTMLElement>('[data-tutor-log]')!;
    const welcome = root.querySelector<HTMLElement>('[data-tutor-welcome]');
    const form = root.querySelector<HTMLFormElement>('[data-tutor-form]')!;
    const input = root.querySelector<HTMLTextAreaElement>('[data-tutor-input]')!;
    const sendBtn = root.querySelector<HTMLButtonElement>('[data-tutor-send]')!;
    const resetBtn = root.querySelector<HTMLButtonElement>('[data-tutor-reset]')!;
    const offline = root.querySelector<HTMLElement>('[data-tutor-offline]')!;
    const actions = root.querySelector<HTMLElement>('[data-tutor-actions]')!;

    // Tutor-open state lives on <html> so the document-level hover listeners
    // (which may have been attached on a previous page and survived a view
    // transition) can read fresh state instead of stale closure variables.
    const open = () => {
      panel.classList.remove('hidden');
      fab.classList.add('hidden');
      document.documentElement.classList.add('tutor-is-open');
      setTimeout(() => input.focus(), 50);
    };
    const close = () => {
      panel.classList.add('hidden');
      fab.classList.remove('hidden');
      document.documentElement.classList.remove('tutor-is-open');
      hideHoverMenuGlobal();
    };

    fab.addEventListener('click', open);
    closeBtn.addEventListener('click', close);
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !panel.classList.contains('hidden')) close();
    });

    if (!endpoint) {
      offline.classList.remove('hidden');
      form.classList.add('hidden');
      actions.classList.add('hidden');
      return;
    }

    const history: Msg[] = [];
    let sentContextOnce = false;

    const appendMessage = (role: Msg['role'], content: string): HTMLElement => {
      if (welcome && !welcome.classList.contains('hidden')) welcome.classList.add('hidden');
      const wrap = document.createElement('div');
      wrap.className = role === 'user' ? 'flex justify-end' : 'flex justify-start';
      const bubble = document.createElement('div');
      bubble.className = role === 'user'
        ? 'max-w-[85%] rounded-2xl rounded-br-sm bg-accent-600 text-white px-3 py-2 text-sm'
        : 'max-w-[85%] rounded-2xl rounded-bl-sm bg-ink-100 dark:bg-ink-800 text-ink-900 dark:text-ink-100 px-3 py-2 text-sm';
      bubble.innerHTML = renderMarkdown(content || '…');
      wrap.appendChild(bubble);
      log.appendChild(wrap);
      log.scrollTop = log.scrollHeight;
      return bubble;
    };

    const setBusy = (busy: boolean) => {
      sendBtn.disabled = busy;
      input.disabled = busy;
      actions.querySelectorAll('button').forEach((b) => (b as HTMLButtonElement).disabled = busy);
    };

    const parseSSELine = (line: string): string | null => {
      if (!line.startsWith('data:')) return null;
      const payload = line.slice(5).trim();
      if (!payload || payload === '[DONE]') return null;
      try {
        const obj = JSON.parse(payload);
        // Legacy Workers AI text generation models (Llama 3.1, etc.).
        if (typeof obj.response === 'string') return obj.response;
        if (typeof obj.delta === 'string') return obj.delta;
        // OpenAI-compatible chat completions (Gemma 4, gpt-oss, llama-4, etc.).
        const choice = Array.isArray(obj.choices) ? obj.choices[0] : null;
        if (choice) {
          if (typeof choice.delta?.content === 'string') return choice.delta.content;
          if (typeof choice.message?.content === 'string') return choice.message.content;
          if (typeof choice.text === 'string') return choice.text;
        }
        return null;
      } catch {
        return null;
      }
    };

    // ask() sends `prompt` to the model. If `displayLabel` is provided it is
    // shown as the user-side bubble in the chat log instead of the raw prompt
    // (used by the hover-to-explain feature so the chat doesn't get cluttered
    // with copy-pasted passages).
    const TYPING_DOTS_HTML = '<span class="tutor-typing-dots" aria-label="Tutor is typing"><span></span><span></span><span></span></span>';
    const CURSOR_HTML = '<span class="tutor-cursor" aria-hidden="true"></span>';

    const ask = async (prompt: string, displayLabel?: string) => {
      history.push({ role: 'user', content: prompt });
      appendMessage('user', displayLabel ?? prompt);
      const bubble = appendMessage('assistant', '');
      bubble.innerHTML = TYPING_DOTS_HTML;
      bubble.classList.add('tutor-streaming');
      let acc = '';
      setBusy(true);

      const body: Record<string, unknown> = {
        messages: history,
        guideTitle: guideTitle || undefined,
      };
      if (!sentContextOnce) {
        const ctx = getGuideContext();
        if (ctx) body.guideContext = ctx;
        sentContextOnce = true;
      }

      try {
        const res = await fetch(`${endpoint.replace(/\/$/, '')}/tutor`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(body),
        });
        if (!res.ok) {
          const err = await res.json().catch(() => ({ error: `HTTP ${res.status}` }));
          bubble.innerHTML = renderMarkdown(`*${err.error ?? 'Something went wrong.'}*`);
          return;
        }
        if (!res.body) {
          bubble.innerHTML = renderMarkdown('*No response body.*');
          return;
        }
        const reader = res.body.getReader();
        const decoder = new TextDecoder();
        let buf = '';
        while (true) {
          const { value, done } = await reader.read();
          if (done) break;
          buf += decoder.decode(value, { stream: true });
          const lines = buf.split('\n');
          buf = lines.pop() ?? '';
          for (const line of lines) {
            const chunk = parseSSELine(line);
            if (chunk) {
              acc += chunk;
              bubble.innerHTML = renderMarkdown(acc) + CURSOR_HTML;
              log.scrollTop = log.scrollHeight;
            }
          }
        }
        history.push({ role: 'assistant', content: acc });
      } catch {
        bubble.innerHTML = renderMarkdown('*Network error. Try again.*');
      } finally {
        // Drop the streaming pulse and finalize the bubble. If the stream
        // closed without sending any content (model refused, safety filter,
        // empty stop reason, etc.), don't leave the typing dots animating
        // forever, replace them with a fallback so the user knows the
        // request finished.
        bubble.classList.remove('tutor-streaming');
        if (acc) {
          bubble.innerHTML = renderMarkdown(acc);
        } else if (bubble.querySelector('.tutor-typing-dots')) {
          bubble.innerHTML = renderMarkdown('*No reply came back. Try again, or rephrase the question.*');
        }
        setBusy(false);
        if (!input.disabled) input.focus();
      }
    };

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const q = input.value.trim();
      if (!q) return;
      input.value = '';
      ask(q);
    });

    input.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' && !e.shiftKey) {
        e.preventDefault();
        form.requestSubmit();
      }
    });

    resetBtn.addEventListener('click', () => {
      history.length = 0;
      sentContextOnce = false;
      log.innerHTML = '';
      if (welcome) {
        welcome.classList.remove('hidden');
        log.appendChild(welcome);
      }
      input.focus();
    });

    actions.querySelectorAll<HTMLButtonElement>('[data-tutor-action]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const key = btn.dataset.tutorAction ?? '';
        const prompt = ACTION_PROMPTS[key];
        if (prompt) ask(prompt);
      });
    });

    // Register THIS page's ask/open with the document-global hover system.
    // Re-assigning each navigation means stale closures from old pages are
    // discarded instead of stacking up as dead listeners.
    g_currentAsk = (prompt, label) => {
      if (panel.classList.contains('hidden')) open();
      ask(prompt, label);
    };
  };

  /* ---------- Hover-to-explain (document-global wiring, attached once) ----- */
  // Lives outside init() so listeners aren't duplicated across view-transition
  // navigations and so the gate is the live <html> class, not a stale closure
  // variable. Also handles the "menu disappears before I can click" gap with
  // a 220ms hide delay plus an invisible CSS bridge under the menu.

  let g_hoverEl: HTMLElement | null = null;
  let g_hoverMenu: HTMLElement | null = null;
  let g_hideTimer: number | null = null;
  // Re-assigned by each page's init() so the hover menu always routes to the
  // current page's chat panel (not a stale one from a previous navigation).
  let g_currentAsk: ((prompt: string, label?: string) => void) | null = null;

  const cancelHide = () => {
    if (g_hideTimer != null) { clearTimeout(g_hideTimer); g_hideTimer = null; }
  };

  const hideHoverMenuGlobal = () => {
    cancelHide();
    if (g_hoverEl) g_hoverEl.classList.remove('tutor-explain-target');
    g_hoverEl = null;
    if (g_hoverMenu) g_hoverMenu.classList.remove('is-open');
  };

  const scheduleHide = () => {
    cancelHide();
    g_hideTimer = window.setTimeout(() => hideHoverMenuGlobal(), 220);
  };

  const buildHoverMenu = (): HTMLElement => {
    const m = document.createElement('div');
    m.setAttribute('data-tutor-hover-menu', '');
    m.setAttribute('role', 'toolbar');
    m.setAttribute('aria-label', 'Re-explain this passage');
    m.innerHTML = `
      <button type="button" data-explain="simpler" title="Re-explain in simpler words">
        <span aria-hidden="true">🧠</span><span>Simpler</span>
      </button>
      <button type="button" data-explain="caveman" title="Re-explain in caveman terms">
        <span aria-hidden="true">🦴</span><span>Caveman</span>
      </button>
    `;
    m.addEventListener('mouseenter', cancelHide);
    m.addEventListener('mouseleave', scheduleHide);
    m.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest('button[data-explain]') as HTMLButtonElement | null;
      if (!btn || !g_hoverEl) return;
      const kind = btn.dataset.explain as 'simpler' | 'caveman';
      const passage = (g_hoverEl.innerText || '').replace(/\s+/g, ' ').trim();
      if (!passage) return;
      hideHoverMenuGlobal();
      // No registered handler means init() bailed before wiring up (e.g. the
      // tutor endpoint env var isn't set, so the panel is showing "Tutor not
      // configured"). Nothing useful to do here.
      if (!g_currentAsk) return;
      const truncated = passage.length > 60 ? passage.slice(0, 60) + '...' : passage;
      const label = kind === 'simpler'
        ? `🧠 Explain simpler: "${truncated}"`
        : `🦴 In caveman terms: "${truncated}"`;
      const prompt = kind === 'simpler'
        ? `Re-explain the passage below in really simple words, like you're talking to a 7th-grader who has never seen this material. Use one short concrete analogy. 100 words maximum.\n\nPassage:\n"""\n${passage}\n"""`
        : `Re-explain the passage below in caveman speak. Tiny vocabulary, short blunt sentences, mostly one syllable. Subject, verb, object. Like this: "Sun hot. Plant eat sun. Plant make food." Match that style for the whole reply. Keep the facts correct. 60 words maximum.\n\nPassage:\n"""\n${passage}\n"""`;
      g_currentAsk(prompt, label);
    });
    document.body.appendChild(m);
    return m;
  };

  const positionHoverMenu = (target: HTMLElement) => {
    if (!g_hoverMenu) return;
    g_hoverMenu.classList.add('is-open');
    const r = target.getBoundingClientRect();
    const mw = g_hoverMenu.offsetWidth || 200;
    const mh = g_hoverMenu.offsetHeight || 40;
    // Sit the menu so its bottom OVERLAPS the top of the block by 6px. That
    // way moving the cursor up from the text never crosses an empty gap.
    const overlap = 6;
    const top = window.scrollY + r.top - mh + overlap;
    const left = Math.max(8, window.scrollX + r.right - mw);
    g_hoverMenu.style.top = `${Math.max(window.scrollY + 4, top)}px`;
    g_hoverMenu.style.left = `${left}px`;
  };

  const showHoverMenu = (target: HTMLElement) => {
    cancelHide();
    if (!g_hoverMenu) g_hoverMenu = buildHoverMenu();
    if (g_hoverEl && g_hoverEl !== target) g_hoverEl.classList.remove('tutor-explain-target');
    g_hoverEl = target;
    target.classList.add('tutor-explain-target');
    positionHoverMenu(target);
  };

  const isEligibleHoverTarget = (el: Element | null): el is HTMLElement => {
    if (!el) return false;
    if (!(el instanceof HTMLElement)) return false;
    if (el.closest('[data-tutor-root]')) return false;
    if (el.closest('[data-tutor-hover-menu]')) return false;
    if (el.closest('.not-prose')) return false;
    if (!el.closest('article .prose')) return false;
    return true;
  };

  const wireHoverGlobalOnce = () => {
    const w = window as any;
    if (w.__tutorHoverWired) return;
    w.__tutorHoverWired = true;

    document.addEventListener('mouseover', (e) => {
      if (!document.documentElement.classList.contains('tutor-is-open')) return;
      const target = (e.target as HTMLElement | null)?.closest(HOVER_BLOCK_SELECTOR) as HTMLElement | null;
      if (!isEligibleHoverTarget(target)) return;
      const text = (target.innerText || '').trim();
      if (text.length < 20) return;
      if (target === g_hoverEl) {
        cancelHide();
        return;
      }
      showHoverMenu(target);
    });

    document.addEventListener('mouseout', (e) => {
      if (!g_hoverEl) return;
      const related = e.relatedTarget as HTMLElement | null;
      if (related && (g_hoverEl.contains(related) || related.closest('[data-tutor-hover-menu]'))) return;
      // Don't yank it instantly: give the cursor time to land on the menu.
      scheduleHide();
    });

    // Reposition on scroll/resize so the menu tracks the block.
    let raf = 0;
    const reflow = () => {
      if (!g_hoverEl || !g_hoverMenu?.classList.contains('is-open')) return;
      cancelAnimationFrame(raf);
      raf = requestAnimationFrame(() => positionHoverMenu(g_hoverEl!));
    };
    window.addEventListener('scroll', reflow, { passive: true });
    window.addEventListener('resize', reflow);
  };
  wireHoverGlobalOnce();

  init();
  document.addEventListener('astro:after-swap', init);
</script>
