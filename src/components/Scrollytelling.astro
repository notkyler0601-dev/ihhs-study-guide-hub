---
// Newsroom-style scroll-driven storytelling via Scrollama.
// Pin a sticky visualization (the "graphic") while scrollable text "steps" trigger state changes.
//
// Usage in MDX:
//   <Scrollytelling
//     graphic={`<img id="diagram" src="/photosynthesis.svg" />`}
//     steps={[
//       { id: 'intro',  body: '<h3>Sunlight hits chlorophyll</h3><p>...</p>' },
//       { id: 'split',  body: '<h3>Water is split</h3><p>...</p>' },
//       { id: 'cycle',  body: '<h3>Calvin cycle builds glucose</h3><p>...</p>' },
//     ]}
//     onStep={`(stepId) => { document.getElementById('diagram').dataset.stage = stepId; }`}
//   />
interface Step {
  id: string;
  body: string;
}
interface Props {
  graphic: string;
  steps: Step[];
  onStep?: string;
  graphicHeight?: string;
}
const { graphic, steps, onStep = '', graphicHeight = '70vh' } = Astro.props;
const id = 'scroll-' + Math.random().toString(36).slice(2, 9);
---

<section class="not-prose my-12 overflow-x-hidden" id={id} data-scrolly data-scrolly-id={id}>
  <div class="grid lg:grid-cols-[1fr_minmax(0,400px)] gap-6 items-start">
    <div data-scrolly-graphic class="lg:sticky lg:top-24 surface rounded-2xl flex items-center justify-center overflow-hidden min-w-0" style={`min-height: ${graphicHeight}; box-sizing: border-box;`}>
      <div class="w-full h-full relative" style={`min-height: ${graphicHeight};`}>
        <Fragment set:html={graphic} />
      </div>
    </div>
    <div class="space-y-6 lg:space-y-[35vh] py-2 lg:py-[15vh] min-w-0">
      {steps.map((step, i) => (
        <article data-scrolly-step={step.id} class="surface rounded-xl p-6 pl-10 transition-all data-[active=true]:border-accent-500 data-[active=true]:shadow-glow relative">
          <span class="absolute top-5 left-4 inline-flex items-center justify-center h-7 w-7 rounded-full bg-accent-700 text-white text-xs font-mono font-semibold">{i + 1}</span>
          <Fragment set:html={step.body} />
        </article>
      ))}
    </div>
  </div>
  <div class="hidden lg:block mt-4 text-center text-xs text-ink-500">↓ scroll to walk through each step ↓</div>
  <script type="application/json" data-scrolly-onstep set:html={JSON.stringify(onStep)}></script>
</section>

<script>
  import scrollama from 'scrollama';

  const setupOne = (root: HTMLElement) => {
    if (root.dataset.bound) return;
    root.dataset.bound = '1';
    const id = root.dataset.scrollyId;
    if (!id) return;
    const onStepRaw = (root.querySelector('[data-scrolly-onstep]')?.textContent || '""');
    let onStep = '';
    try { onStep = JSON.parse(onStepRaw); } catch {}

    const scroller = scrollama();
    scroller
      .setup({ step: `#${id} [data-scrolly-step]`, offset: 0.55, debug: false })
      .onStepEnter(({ element, direction }) => {
        root.querySelectorAll('[data-scrolly-step]').forEach((el) => el.removeAttribute('data-active'));
        element.setAttribute('data-active', 'true');
        if (onStep) {
          try {
            const fn = new Function('stepId', 'direction', `return (${onStep})(stepId, direction);`);
            fn(element.getAttribute('data-scrolly-step'), direction);
          } catch (e) { console.warn('onStep failed', e); }
        }
      });
    window.addEventListener('resize', () => scroller.resize());
    // Trigger initial state for the first step so the graphic isn't blank on load.
    const firstStep = root.querySelector('[data-scrolly-step]');
    if (firstStep && onStep) {
      try {
        const fn = new Function('stepId', 'direction', `return (${onStep})(stepId, direction);`);
        fn(firstStep.getAttribute('data-scrolly-step'), 'down');
        firstStep.setAttribute('data-active', 'true');
      } catch {}
    }
  };

  const init = () => {
    document.querySelectorAll<HTMLElement>('[data-scrolly]').forEach(setupOne);
  };
  init();
  document.addEventListener('astro:after-swap', init);
</script>
