---
interface Props {
  intensity?: 'subtle' | 'normal' | 'bold';
}
const { intensity = 'subtle' } = Astro.props;

const opacityClass = {
  subtle: 'opacity-30 dark:opacity-25',
  normal: 'opacity-50 dark:opacity-35',
  bold: 'opacity-70 dark:opacity-45',
}[intensity];
---

<div
  class:list={['pointer-events-none fixed inset-0 -z-10 overflow-hidden', opacityClass]}
  aria-hidden="true"
>
  <div class="absolute -top-1/3 -left-1/4 h-[600px] w-[600px] rounded-full blur-3xl animate-aurora-slow"
       style="background: radial-gradient(circle, rgba(185,28,28,0.40), transparent 70%);">
  </div>
  <div class="absolute top-1/4 -right-1/4 h-[500px] w-[500px] rounded-full blur-3xl animate-aurora-slow"
       style="background: radial-gradient(circle, rgba(127,29,29,0.30), transparent 70%); animation-delay: -7s;">
  </div>
  <div class="absolute -bottom-1/4 left-1/3 h-[500px] w-[500px] rounded-full blur-3xl animate-aurora-slow"
       style="background: radial-gradient(circle, rgba(220,38,38,0.25), transparent 70%); animation-delay: -14s;">
  </div>
</div>
