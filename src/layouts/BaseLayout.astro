---
import { ClientRouter } from 'astro:transitions';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CommandPalette from '../components/CommandPalette.astro';
import AuroraBackground from '../components/AuroraBackground.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  showAurora?: boolean;
}
const { title, description = 'Deep-dive interactive study guides built by IHHS students.', showAurora = true } = Astro.props;
const fullTitle = title === 'IHHS Study Guide Hub' ? title : `${title} · IHHS Study Guide Hub`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/png" href="/ihhs-logo.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <script is:inline>
      // Default to light mode. Dark mode is opt-in via the theme toggle and
      // only kicks in if the user has explicitly selected it before.
      (() => {
        if (localStorage.getItem('theme') === 'dark') {
          document.documentElement.classList.add('dark');
        }
        // Apply persisted accessibility preferences before paint so there's
        // no flash of the wrong font.
        if (localStorage.getItem('a11y:dyslexia-font') === '1') {
          document.documentElement.classList.add('a11y-dyslexia-font');
        }
        if (localStorage.getItem('a11y:reduce-motion') === '1') {
          document.documentElement.classList.add('a11y-reduce-motion');
        }
      })();
    </script>
    <script type="speculationrules" is:inline set:html={JSON.stringify({
      prerender: [
        { where: { href_matches: '/guides/*' }, eagerness: 'moderate' },
        { where: { href_matches: '/dashboard' }, eagerness: 'moderate' },
        { where: { href_matches: '/library' }, eagerness: 'moderate' },
        { where: { href_matches: '/review' }, eagerness: 'moderate' }
      ],
      prefetch: [
        { where: { href_matches: '/*' }, eagerness: 'conservative' }
      ]
    })} />
    <ClientRouter />
  </head>
  <body class="min-h-screen flex flex-col">
    {showAurora && <AuroraBackground />}
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
    <CommandPalette />
  </body>
</html>
